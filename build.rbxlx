                <Item class="ModuleScript" referent="149">
                  <Properties>
                    <string name="Name">announce</string>
                    <string name="Source">return {
	Name = "announce";
	Aliases = {"m"};
	Description = "Makes a server-wide announcement.";
	Group = "DefaultAdmin";
	Args = {
		{
			Type = "string";
			Name = "text";
			Description = "The announcement text.";
