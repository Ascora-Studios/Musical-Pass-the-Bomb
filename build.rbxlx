          <Item class="ModuleScript" referent="461">
            <Properties>
              <string name="Name">LeaderboardController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Teams = game:GetService("Teams")

-- Packages
local Packages = ReplicatedStorage.Packages
local Replica = require(Packages.Replica)
local Trove = require(Packages.Trove)

-- Modules
local Shared = ReplicatedStorage.Shared
local MathUtil = require(Shared.MathUtil)
local GuiUtil = require(Shared.GuiUtil)

-- Assets
local Assets = ReplicatedStorage.Assets
local UI = Assets.UI

-- Leaderboards
local Leaderboards = workspace:WaitForChild("Leaderboards")

--
local RANK_COLORS = {
	[1] = Color3.fromRGB(255, 170, 0),
	[2] = Color3.fromRGB(171, 171, 171),
	[3] = Color3.fromRGB(170, 85, 0),
}

local DEFAULT_COLOR = Color3.fromRGB(255, 255, 255)

local FORMAT_LEADERBOARD_DATA = {
	Default = function(amount)
		return GuiUtil.ConvertNumberWithCommas(MathUtil.RoundUpTo2Dec(amount))
	end,
}

--
local LeaderboardController = {
	--
	_cachedNames = {},
	_cachedThumbnails = {},

	--
	_hasSetup = false,
	_refreshTime = 0,

	--
	_cleaner = Trove.new(),
}

function LeaderboardController:RefreshLeaderboard(updatedLeaderboardData: {})
	--
	self._cleaner:Clean()

	--
	for leaderboardKey, leaderboardData in updatedLeaderboardData do
		self._cleaner:Add(task.spawn(function()
			--
			local leaderboard = Leaderboards:WaitForChild(leaderboardKey, 2)
			local leaderboardUI = leaderboard and leaderboard.Board:FindFirstChild("LeaderboardUI")
			if not leaderboardUI then
				return
			end

			-- Remove old leaderboard data
			local container = leaderboardUI.Holder.Container

			--
			for rank, data in leaderboardData do
				if tonumber(data.key) < 1 then
					return
				end

				--
				local playerName = self._cachedNames[data.key]
				if not playerName then
					local success, name = pcall(function()
						return Players:GetNameFromUserIdAsync(data.key)
					end)

					if success then
						playerName = name
						self._cachedNames[data.key] = name
					else
						playerName = ""
					end
				end

				local formatFunc = FORMAT_LEADERBOARD_DATA[leaderboardKey] or FORMAT_LEADERBOARD_DATA.Default

				--
				local template: Frame = self._cleaner:Clone(leaderboardUI.Templates.EntryTemplate)
				template.Amount.Text = formatFunc(data.value)
				template.LayoutOrder = rank
				template.PlayerName.Text = playerName:upper() or ""
				template.Rank.Text = `#{rank}`
				template.BackgroundColor3 = RANK_COLORS[rank] or DEFAULT_COLOR
				template.Visible = true
				template.Parent = container

				self._cleaner:Add(task.spawn(function()
					local playerThumbnail = self._cachedThumbnails[data.key]

					if not playerThumbnail then
						local success, thumbnail = pcall(function()
							return Players:GetUserThumbnailAsync(
								data.key,
								Enum.ThumbnailType.HeadShot,
								Enum.ThumbnailSize.Size48x48
							)
						end)

						if success then
							playerThumbnail = thumbnail
							self._cachedThumbnails[data.key] = thumbnail
						end
					end

					if template then
						template.PlayerIcon.Image = playerThumbnail
					end
				end))
			end
		end))
	end
end

function LeaderboardController:SetupLeaderboard(initialLeaderboardData: { any: { any } })
	--
	local leaderboardUIs = {}
	for key, _ in initialLeaderboardData do
		local leaderboard = Leaderboards:WaitForChild(key, 3)
		if leaderboard then
			local leaderboardUI = UI.LeaderboardUI:Clone()
			leaderboardUI.Parent = leaderboard:WaitForChild("Board")
			table.insert(leaderboardUIs, leaderboardUI)
		end
	end

	--
	--[[task.spawn(function()
		while true do
			local timeLeft = self._refreshTime - workspace:GetServerTimeNow()

			for _, v in leaderboardUIs do
				v.Holder.RefreshTitle.Visible = not (timeLeft <= 0)
				v.Holder.RefreshTime.Text = timeLeft <= 0 and "Refreshing" or `{GuiUtil.ConvertSecondsToMMSS(timeLeft)}`
			end

			task.wait(1)
		end
	end)]]

	self:RefreshLeaderboard(initialLeaderboardData)
	self._hasSetup = true
end

function LeaderboardController:OnInit()
	--
	Replica.OnNew("Leaderboard", function(replica)
		--
		self._refreshTime = replica.Data.RefreshTime
		replica:OnSet({ "RefreshTime" }, function(newTime)
			self._refreshTime = newTime
		end)

		--
		self:SetupLeaderboard(replica.Data.LeaderboardData)
		replica:OnSet({ "LeaderboardData" }, function(leaderboardData)
			self:RefreshLeaderboard(leaderboardData)
		end)
	end)
end

--

return LeaderboardController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="462">
            <Properties>
              <string name="Name">NotificationController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TextChatService = game:GetService("TextChatService")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local Spr = require(Packages.Spr)

-- Local Player
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

--
local SoundController

--
local DEFAULT_DURATION = 3

--
local NotificationController = {
	NotifyNormalEvent = BridgeNet2.ReferenceBridge("NotifyNormal"),
	NotifyChatEvent = BridgeNet2.ReferenceBridge("NotifyChat"),

	_activeNotifications = {},
}

-- Shows a notification on the screen of the player
function NotificationController:NotifyNormal(notification: string, duration: number?, sound: string?, scale: number?)
	--
	local ui = self.UI
	local normalNotificationContainer = ui.NormalNotificationContainer
	local notificationDuration = duration or DEFAULT_DURATION

	-- If already active
	if self._activeNotifications[notification] then
		local data = self._activeNotifications[notification]
		data.Count = data.Count + 1
		data.TimeLeft = notificationDuration

		-- Update label with [N]
		data.Instance.Text = notification .. " [" .. data.Count .. "]"
		SoundController:PlaySound(sound or "Notify")
		return
	end

	-- Create new notification
	local normalNotificationTemplate = ui.Templates.NormalNotificationTemplate:Clone()
	normalNotificationTemplate.Text = notification
	normalNotificationTemplate.UIScale.Scale = 0.5
	normalNotificationTemplate.Visible = true
	normalNotificationTemplate.Parent = normalNotificationContainer

	-- Effect
	Spr.target(normalNotificationTemplate.UIScale, 0.5, 4, { Scale = scale or 1 })
	SoundController:PlaySound(sound or "Notify")

	-- Track the notification
	local notificationData = {
		Count = 1,
		TimeLeft = notificationDuration,
		Instance = normalNotificationTemplate,
	}
	self._activeNotifications[notification] = notificationData

	-- Timer loop
	task.spawn(function()
		while notificationData.TimeLeft > 0 do
			local dt = task.wait()
			notificationData.TimeLeft = notificationData.TimeLeft - dt
		end

		-- Fade out and cleanup
		TweenService
			:Create(
				normalNotificationTemplate.UIStroke,
				TweenInfo.new(0.5, Enum.EasingStyle.Sine),
				{ Transparency = 1 }
			)
			:Play()
		TweenService
			:Create(normalNotificationTemplate, TweenInfo.new(0.5, Enum.EasingStyle.Sine), { TextTransparency = 1 })
			:Play()

		task.wait(0.5)
		normalNotificationTemplate:Destroy()
		self._activeNotifications[notification] = nil
	end)
end

-- Adds a notification to the chat
function NotificationController:NotifyChat(notificationText: string)
	local rbxSystemTextChannel = TextChatService.TextChannels.RBXSystem
	rbxSystemTextChannel:DisplaySystemMessage(`<font color="#ffffff">{notificationText}</font>`)
end

function NotificationController:OnInit()
	--
	SoundController = require(script.Parent.SoundController)

	--
	self.UI = PlayerGui:WaitForChild("NotificationUI")
end

function NotificationController:OnStart()
	self.NotifyNormalEvent:Connect(function(data)
		if typeof(data) ~= "table" then
			self:NotifyNormal(data)
			return
		end

		self:NotifyNormal(table.unpack(data))
	end)

	self.NotifyChatEvent:Connect(function(notificationText)
		self:NotifyChat(notificationText)
	end)
end

return NotificationController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="463">
            <Properties>
              <string name="Name">PlayerDataController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local Replica = require(Packages.Replica)
local Promise = require(Packages.Promise)

-- Local Player
local LocalPlayer = Players.LocalPlayer

--
local DEFAULT_TIMEOUT = 15

--
local PlayerDataController = {
	_playerDataReplica = nil,
}

function PlayerDataController:GetReplica(timeout: string)
	--
	timeout = timeout or DEFAULT_TIMEOUT
	local getTimeout = os.clock() + timeout

	--
	return Promise.new(function(resolve, reject)
		-- if there player replica has not yet been created, keep trying until it has
		if not self._playerDataReplica then
			repeat
				task.wait()
			until self._playerDataReplica or getTimeout - os.clock() <= 0

			if not self._playerDataReplica then
				reject("Timeout Reached! Player Replica does not exist.")
			end
		end

		--
		resolve(self._playerDataReplica)
	end)
end

function PlayerDataController:GetData(): { any }
	local hasData, playerDataReplica = self:GetReplica():await()
	if not hasData then
		return
	end

	return playerDataReplica.Data
end

function PlayerDataController:GetKey(key: string): any
	local playerData = PlayerDataController:GetData()
	return playerData[key]
end

function PlayerDataController:OnInit()
	Replica.OnNew("PlayerData", function(replica)
		if not (replica.Tags.UserId == LocalPlayer.UserId) then
			return
		end

		self._playerDataReplica = replica
	end)
end

return PlayerDataController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="464">
            <Properties>
              <string name="Name">RagdollController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local Trove = require(Packages.Trove)

-- Shared
local Shared = ReplicatedStorage.Shared
local RagdollShared = require(Shared.RagdollShared)

-- Values
local DEFAULT_RAGDOLL_LENGTH = 3

-- Events
local RagdollPlayer = BridgeNet2.ReferenceBridge(RagdollShared.BRIDGE_NAME)

-- Controllers
local CameraController = require(script.Parent.CameraController)

--
local RagdollController = {
	_trove = nil :: any,
}

function RagdollController:_getCharacter(): Model?
	local player = Players.LocalPlayer
	local character = player.Character
	if not character or not character:FindFirstChild("Humanoid") then
		return nil
	end
	return character
end

function RagdollController:_enableRagdoll(timeLength: number?, pushDirection: Vector3?)
	local character = self:_getCharacter()
	if not character then
		return
	end

	-- Re-ragdoll: refresh the timer (and keep the impulse if one was passed)
	if self._trove then
		self._trove:Destroy()
		self._trove = nil
	end

	local humanoid: Humanoid = character.Humanoid
	local rootPart = character.PrimaryPart

	humanoid:ChangeState(Enum.HumanoidStateType.Physics)
	RagdollShared.EnableRagdoll(character)
	CameraController:SetSubject(character.Head) -- avoid camera bobble

	if pushDirection and rootPart then
		local worldDirection = character:GetPivot():VectorToWorldSpace(pushDirection)
		rootPart:ApplyImpulse(worldDirection * rootPart.AssemblyMass)
	end

	self._trove = Trove.new()
	self._trove:Add(task.delay(timeLength or DEFAULT_RAGDOLL_LENGTH, function()
		self:_disableRagdoll()
	end))
end

function RagdollController:_disableRagdoll()
	local character = self:_getCharacter()
	if not character then
		return
	end

	if self._trove then
		self._trove:Destroy()
		self._trove = nil
	end

	local humanoid: Humanoid = character.Humanoid
	humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
	CameraController:SetSubject(humanoid)
	RagdollShared.DisableRagdoll(character)
end

function RagdollController:ToggleRagdoll(toggle: boolean, timeLength: number?, pushDirection: Vector3?)
	if toggle then
		self:_enableRagdoll(timeLength, pushDirection)
	else
		self:_disableRagdoll()
	end
end

function RagdollController:OnStart()
	RagdollPlayer:Connect(function(payload: RagdollShared.RagdollPayload)
		self:ToggleRagdoll(payload.Toggle, payload.TimeLength, payload.PushDirection)
	end)
end

return RagdollController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="465">
            <Properties>
              <string name="Name">RoundController</string>
              <string name="Source"><![CDATA[--[[
	RoundController

	Mirrors the server's `RoundData` replica and listens to round/bomb-related
	BridgeNet2 events. Exposes empty hook methods you can fill in for visuals,
	UI, sounds, camera effects, etc.

	Hooks (override these — they're called automatically):
	  :OnIntermissionStart()                        - intermission stage began
	  :OnIntermissionWaiting()                      - not enough players; countdown paused
	  :OnIntermissionCountdown(secondsLeft)         - fires every second during intermission (5 → 0)
	  :OnEnterMatchAll()                            - InitMatch stage; runs for BOTH players and spectators (UI swap, etc.)
	  :OnEnterMatchAsPlayer()                       - InitMatch stage; runs ONLY for players in the alive list
	  :OnEnterMatchSpectator()                      - InitMatch stage; runs ONLY for spectators (joined mid-game)
	  :OnMatchStart()                               - Match stage (music timer starts soon)
	  :OnPreElimination(victimInfo)                 - server grace starts; victim about to be eliminated (play effects now)
	  :OnPlayerEliminated(eliminatedInfo, remaining) - player was just eliminated
	  :OnPostElimination(remainingCount)            - server grace starts; circle is about to reset (play effects now)
	  :OnEliminationChoicePrompt(expirationTime)    - LOCAL ONLY; you were eliminated and the match still has > 2 alive — show LEAVE/RESPAWN UI
	  :OnEliminationChoiceResolved(choice)          - LOCAL ONLY; the prompt was answered, timed out, or was cancelled — hide the UI
	                                                  (`choice` is "Respawn" or "Leave"; call :RequestRespawn() / :RequestLeave() to answer)
	  :OnReceiveBomb()                              - YOU just received the bomb
	  :OnOtherPlayerReceiveBomb(player, userId)     - another player just received the bomb
	  :OnBombPassed(player, skipAnim, fromPlayer)   - bomb holder changed; fromPlayer is nil if there is no source
	  :OnMusicStart(explosionTimestamp)             - server set a new explosion timer (music cycle started/resumed)
	  :OnMusicStop()                                - server cleared the explosion timer (music cycle stopped)
	  :OnMatchEnd(winner, placements)               - match over; celebration phase (confetti, winner UI, fanfare, etc.)

	Other helpers:
	  :HasBomb()                                    - true if local player is the bomb holder
	  :IsInMatch()                                  - true if local player is in the alive list (not a spectator)
	  :GetBombHolderUserId()
	  :GetExplosionTimestamp()
	  :GetCurrentStage()
	  :RequestBombPass(direction)                   - "Left" | "Right" | "Front"
	  :RequestRespawn()                             - answer the elimination prompt with RESPAWN (re-enter the match)
	  :RequestLeave()                               - answer the elimination prompt with LEAVE (return to lobby as spectator)
]]

-- Services
local Lighting = game:GetService("Lighting")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local Promise = require(Packages.Promise)
local Trove = require(Packages.Trove)
local Replica = require(Packages.Replica)
local Signal = require(Packages.Signal)
local Spr = require(Packages.Spr)

--
local Assets = ReplicatedStorage.Assets
local Meshes = Assets.Meshes

--
local LocalPlayer = Players.LocalPlayer
local Controls =
	require(LocalPlayer:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule"):WaitForChild("ControlModule"))
local PlayerGui = LocalPlayer.PlayerGui

--
local DEFAULT_TIMEOUT = 15

--
local HudController
local UIController
local SoundController
local PlayerDataController
local AnimationController

--
local RoundController = {
	-- Public signals (in case you'd rather Connect than override)
	OnReplicaReady = Signal.new(),
	OnDataChanged = Signal.new(),

	OnIntermissionStartedSignal = Signal.new(),
	OnIntermissionWaitingSignal = Signal.new(), -- fired when not enough players (countdown paused)
	OnIntermissionCountdownSignal = Signal.new(), -- (secondsLeft: string) fires every ~0.05s during countdown
	OnEnterMatchAllSignal = Signal.new(), -- fires for BOTH players and spectators
	OnEnterMatchAsPlayerSignal = Signal.new(), -- fires only for players in the alive list
	OnEnterMatchSpectatorSignal = Signal.new(), -- fires only for spectators (joined mid-game)
	OnMatchStartedSignal = Signal.new(),
	OnPreEliminationSignal = Signal.new(), -- (victimInfo) fired during PRE_ELIMINATION_GRACE
	OnPlayerEliminatedSignal = Signal.new(), -- (eliminatedInfo, remainingCount)
	OnPostEliminationSignal = Signal.new(), -- (remainingCount) fired during POST_ELIMINATION_GRACE
	OnReceiveBombSignal = Signal.new(),
	OnOtherPlayerReceiveBombSignal = Signal.new(), -- (player: Player?, userId: number)
	OnMusicStartSignal = Signal.new(), -- (explosionTimestamp: number)
	OnMusicStopSignal = Signal.new(),
	OnMatchEndSignal = Signal.new(), -- (winner: { UserId, Name, DisplayName }?, placements: { [number]: any })
	OnEliminationChoicePromptSignal = Signal.new(), -- (expirationTime: number)
	OnEliminationChoiceResolvedSignal = Signal.new(), -- (choice: string) "Respawn" | "Leave"

	-- BridgeNet2 references (server creates with these names)
	RequestBombPassBridge = BridgeNet2.ReferenceBridge("RequestBombPass"),
	SyncBombHolderBridge = BridgeNet2.ReferenceBridge("SyncBombHolder"),
	SyncExplosionTimeBridge = BridgeNet2.ReferenceBridge("SyncExplosionTime"),
	PreEliminationBridge = BridgeNet2.ReferenceBridge("PreElimination"),
	PlayerEliminatedBridge = BridgeNet2.ReferenceBridge("PlayerEliminated"),
	PostEliminationBridge = BridgeNet2.ReferenceBridge("PostElimination"),
	MatchEndBridge = BridgeNet2.ReferenceBridge("MatchEnd"),
	EliminationChoicePromptBridge = BridgeNet2.ReferenceBridge("EliminationChoicePrompt"),
	EliminationChoiceResolvedBridge = BridgeNet2.ReferenceBridge("EliminationChoiceResolved"),
	EliminationChoiceRequestBridge = BridgeNet2.ReferenceBridge("EliminationChoiceRequest"),

	_roundReplica = nil,
	_lastStage = nil,
	_lastBombHolderUserId = nil,
	_explosionTimestamp = 0,
	_countdownEndsAt = 0,
	--
	_gameCleaner = Trove.new(),
	_passCleaner = Trove.new(),
	_musicStopCleaner = Trove.new(),
	_respawnCleaner = Trove.new(),

	_waitingDotsThread = nil :: thread?,
}

----------------------------------------------------------------
-- Replica accessors
----------------------------------------------------------------

function RoundController:GetReplica(timeout: number?)
	timeout = timeout or DEFAULT_TIMEOUT

	return Promise.new(function(resolve, reject)
		local expiresAt = os.clock() + timeout

		if not self._roundReplica then
			repeat
				task.wait()
			until self._roundReplica or os.clock() >= expiresAt

			if not self._roundReplica then
				reject("Timeout reached while waiting for round replica.")
				return
			end
		end

		resolve(self._roundReplica)
	end)
end

function RoundController:GetData(): { [string]: any }?
	local success, replica = self:GetReplica():await()
	if not success then
		return nil
	end

	return replica.Data
end

function RoundController:GetKey(key: string): any
	local data = self:GetData()
	if not data then
		return nil
	end

	return data[key]
end

----------------------------------------------------------------
-- Convenience accessors
----------------------------------------------------------------

function RoundController:GetCurrentStage(): string?
	return self:GetKey("CurrentStage")
end

function RoundController:GetBombHolderUserId(): number?
	return self:GetKey("BombHolderUserId")
end

function RoundController:HasBomb(): boolean
	local holderUserId = self:GetBombHolderUserId()
	return holderUserId == LocalPlayer.UserId
end

function RoundController:GetBomb(): Model?
	return self._bomb
end

-- Returns true if the local player is in the alive list (i.e. an active participant,
-- not someone who joined mid-game or was already eliminated).
function RoundController:IsInMatch(): boolean
	local data = self:GetData()
	if not data or not data.AlivePlayers then
		return false
	end
	for _, entry in data.AlivePlayers do
		if entry.UserId == LocalPlayer.UserId then
			return true
		end
	end
	return false
end

function RoundController:GetExplosionTimestamp(): number
	return self._explosionTimestamp
end

function RoundController:GetTimeUntilExplosion(): number
	if self._explosionTimestamp <= 0 then
		return 0
	end
	return math.max(0, self._explosionTimestamp - workspace:GetServerTimeNow())
end

function RoundController:RequestBombPass(direction: string)
	self.RequestBombPassBridge:Fire(direction)
end

-- Answer the elimination prompt with RESPAWN. Server will re-add you to the
-- alive list, unragdoll, lock movement, and re-circle everyone.
-- Server silently ignores this if you don't currently have an active prompt.
function RoundController:RequestRespawn()
	self.EliminationChoiceRequestBridge:Fire({ Choice = "Respawn" })
end

-- Answer the elimination prompt with LEAVE. Server will unragdoll, restore
-- movement, and teleport you to the lobby spawn as a spectator.
-- Server silently ignores this if you don't currently have an active prompt.
function RoundController:RequestLeave()
	self.EliminationChoiceRequestBridge:Fire({ Choice = "Leave" })
end

----------------------------------------------------------------
-- ↓↓↓ HOOKS — fill these in for your UI / VFX / SFX / camera ↓↓↓
----------------------------------------------------------------

function RoundController:ToggleGameControls(show: boolean)
	local ui = self.GameUI
	Spr.target(ui.Bottom, 0.7, 2.5, { Position = show and UDim2.fromScale(0.5, 0.72) or UDim2.fromScale(0.5, 1.1) })
end

function RoundController:TogglePassButtons(show: boolean)
	local buttons = self.GameUI.Bottom.Arrows
	buttons.Visible = show

	--
	self._passCleaner:Clean()

	if not show then
		return
	end

	-- Bind the buttons
	for _, v in buttons:GetChildren() do
		self._passCleaner:Add(UIController:BindButtonClick(v, function()
			self:RequestBombPass(v.Name)
		end, true))
	end
end

-- Called when the intermission stage begins.
-- Use for: showing intermission UI, fading match HUD, lobby music, etc.
function RoundController:OnIntermissionStart()
	--
	local ui = self.GameUI.Top
	local intermission = ui.Intermission
	local winnerFrame = ui.Winner

	--
	HudController:ShowHud()
	Spr.target(intermission, 0.7, 2.5, { Position = UDim2.fromScale(0.5, 0.325) })
	Spr.target(winnerFrame, 0.7, 2.5, { Position = UDim2.fromScale(0.5, -0.5) })
end

-- Called when the server is waiting for more players (countdown paused / not yet started).
-- Use for: showing "Waiting for players..." text, hiding the countdown label, etc.
function RoundController:OnIntermissionWaiting()
	--
	local ui = self.GameUI.Top
	local intermission = ui.Intermission
	local winnerFrame = ui.Winner

	--
	Spr.target(intermission, 0.7, 2.5, { Position = UDim2.fromScale(0.5, 0.325) })
	Spr.target(winnerFrame, 0.7, 2.5, { Position = UDim2.fromScale(0.5, -0.5) })
	intermission.Countdown.Visible = false
	intermission.NotEnoughPlayersDescription.Visible = true

	-- Cancel any existing dots animation before starting a fresh one.
	self:_stopWaitingDots()

	self._waitingDotsThread = task.spawn(function()
		local suffixes = { ".", "..", "..." }
		local i = 0
		while true do
			i = (i % #suffixes) + 1
			intermission.Title.Text = "WAITING FOR PLAYERS" .. suffixes[i]
			task.wait(0.5)
		end
	end)
end

-- Called every second during the intermission countdown.
-- `secondsLeft` counts down from the duration to 0 (inclusive).
-- Use for: updating a countdown label, playing a tick SFX at 3-2-1, etc.
function RoundController:OnIntermissionCountdown(secondsLeft: string)
	--
	local ui = self.GameUI.Top
	local intermission = ui.Intermission

	-- Stop the dots animation now that a real countdown is running.
	self:_stopWaitingDots()

	--
	intermission.Countdown.Text = secondsLeft
	intermission.Countdown.Visible = true
	intermission.Title.Text = "GAME IS STARTING!"
	intermission.NotEnoughPlayersDescription.Visible = false

	-- Change countdown color when 3 seconds or fewer remain.
	local rawLeft = tonumber(secondsLeft) or 0
	if rawLeft <= 3 then
		intermission.Countdown.TextColor3 = Color3.fromRGB(255, 50, 50) -- urgent red
	else
		intermission.Countdown.TextColor3 = Color3.fromRGB(255, 255, 255) -- default white
	end
end

-- Called when InitMatch starts (you've just been spawned in the circle, but
-- the music timer hasn't started yet). Runs for BOTH players and spectators.
-- Use for: closing intermission UI, fade-in match HUD, camera framing, etc.
-- Player-only setup goes in OnEnterMatchAsPlayer; spectator-only setup goes in OnEnterMatchSpectator.
function RoundController:OnEnterMatchAll()
	-- Leaving intermission — ensure the dots animation is cleaned up.
	self:_stopWaitingDots()
	HudController:HideHud()

	local ui = self.GameUI

	local top = ui.Top
	local inGame = top.InGame
	local intermission = top.Intermission

	Spr.target(intermission, 0.7, 3, { Position = UDim2.fromScale(0.5, -0.25) })
	task.delay(3, function()
		Spr.target(inGame, 0.7, 2.5, { Position = UDim2.fromScale(0.5, 0.05) })
	end)

	SoundController:StartGameMusic(self:GetKey("MusicToPlay"))
	SoundController:SwitchBGM("Game", 3.5)
end

-- Called when InitMatch starts AND the local player is in the alive list.
-- Use for: ready-text animation, disabling default controls, showing the in-match HUD, etc.
function RoundController:OnEnterMatchAsPlayer()
	local ui = self.GameUI
	local middle = ui.Middle
	local readyText = middle.ReadyText
	local bottom = ui.Bottom

	readyText:AddTag("UISway")
	readyText.UIScale.Scale = 0

	Spr.target(readyText.UIScale, 0.45, 1.5, { Scale = 1 })
	readyText.Visible = true

	SoundController:PlaySound("StartRound")
	self._gameCleaner:Add(task.delay(3, function()
		Spr.target(readyText.UIScale, 0.5, 1.5, { Scale = 0 })
		readyText.UIScale.Scale = 0

		task.wait(1)
		readyText.Visible = false
		readyText:RemoveTag("UISway")
	end))

	-- Reset state if the match ends mid-animation.
	self._gameCleaner:Add(function()
		readyText:RemoveTag("UISway")
		readyText.UIScale.Scale = 0
		readyText.Visible = false
	end)

	Controls:Disable()
end

-- Called when InitMatch starts AND the local player is NOT in the alive list
-- (joined mid-game). Use for: spectator camera, "Watching" UI, free-cam controls, etc.
function RoundController:OnEnterMatchSpectator() end

-- Called when the Match stage actually starts (music timer is now ticking).
-- Use for: starting the music sound on the client, showing the bomb timer UI,
-- enabling pass buttons, etc.
function RoundController:OnMatchStart()
	local bomb = self._gameCleaner:Clone(Meshes.Bomb)
	bomb.Parent = workspace.Main
	self._bomb = bomb

	local player = Players:GetPlayerByUserId(self:GetBombHolderUserId())
	if player then
		self:OnBombPassed(player, true, nil)
	end

	if self:IsInMatch() then
		self:ToggleGameControls(true)
	end
end

-- Called when the timer expires and the server enters the PRE_ELIMINATION_GRACE window.
-- `victimInfo` is { UserId, Name, DisplayName } of the player about to be eliminated.
-- The actual elimination fires after GameConfigs.PRE_ELIMINATION_GRACE seconds.
-- Use for: explosion wind-up SFX, camera shake build-up, highlight the victim, etc.
function RoundController:OnPreElimination(victimInfo: { [string]: any }?)
	--
	local ui = self.GameUI
	local middle = ui.Middle
	local notification = middle.Notification

	local name = victimInfo and victimInfo.Name or "unknown"
	local player = Players:GetPlayerByUserId(victimInfo and victimInfo.UserId or 0)

	if not player then
		return
	end

	task.wait(1.5)

	local character = player.Character
	if not character or not character.Parent then
		return
	end

	local camera = workspace.CurrentCamera

	SoundController:PlaySound("OnEliminated")

	if self:IsInMatch() then
		camera.CameraType = Enum.CameraType.Scriptable
		camera.CFrame = character:GetPivot()
			* CFrame.new(0, 5, -15)
			* CFrame.Angles(0, math.rad(180), 0)
			* CFrame.Angles(math.rad(-15), 0, 0)

		local tween = TweenService:Create(camera, TweenInfo.new(5), { CFrame = camera.CFrame * CFrame.new(0, 0, -5) })
		tween:Play()

		self._gameCleaner:Add(function()
			if tween then
				tween:Cancel()
			end
		end)
	end

	--
	task.delay(1, function()
		local eliminatedNotificationText = notification.EliminatedNotification:Clone()
		eliminatedNotificationText.Title.UIScale.Scale = 0
		eliminatedNotificationText.Title.Text = `{name:upper()} HAS BEEN ELIMINATED!`
		eliminatedNotificationText.Visible = true
		eliminatedNotificationText.Parent = notification

		eliminatedNotificationText.Title:SetAttribute("Amplitude", 1)
		eliminatedNotificationText.Title:AddTag("UISway")

		Spr.target(eliminatedNotificationText.Title.UIScale, 0.7, 2.5, { Scale = 1 })

		task.delay(3, function()
			Spr.target(eliminatedNotificationText.Title.UIScale, 0.7, 2.5, { Scale = 0 })
			task.wait(3)
			eliminatedNotificationText:Destroy()
		end)
	end)
end

-- Called right after an elimination and before survivors are re-circled
-- (server is in the POST_ELIMINATION_GRACE window).
-- `remainingCount` is how many players are still alive.
-- The circle reset + new music cycle fires after GameConfigs.POST_ELIMINATION_GRACE seconds.
-- Use for: "X players remain" banner, arena reset animation, breath-of-air SFX, etc.
function RoundController:OnPostElimination(remainingCount: number)
	--
	local ui = self.GameUI
	local middle = ui.Middle
	local readyText = middle.ReadyText

	if not self:IsInMatch() then
		return
	end

	self._gameCleaner:Add(task.delay(4, function()
		readyText:AddTag("UISway")

		readyText.UIScale.Scale = 0

		Spr.target(readyText.UIScale, 0.45, 2, { Scale = 1 })
		readyText.Visible = true

		self._gameCleaner:Add(task.delay(2.8, function()
			Spr.target(readyText.UIScale, 0.5, 2, { Scale = 0 })
			readyText.UIScale.Scale = 0

			task.wait(1)
			readyText.Visible = false
			readyText:RemoveTag("UISway")
		end))
	end))

	workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
end

-- Called whenever ANY player gets eliminated (including yourself).
-- `eliminatedInfo` is { UserId, Name, DisplayName }.
-- Use for: explosion VFX/SFX, screen shake, kill feed, particle effects, etc.
function RoundController:OnPlayerEliminated(elimatedInfo: { [string]: any }?, remainingCount: number)
	-- Only collapse the local player's match UI when THEY were the one eliminated.
	-- Otherwise other players' eliminations would hide the still-active HUD.
	if elimatedInfo and elimatedInfo.UserId == LocalPlayer.UserId then
		self._passCleaner:Clean()
		self._musicStopCleaner:Clean()
		HudController:HideHud()
		self:ToggleGameControls(false)
		self:TogglePassButtons(false)
		Controls:Enable()
		workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
	end

	if self._bomb and self._bomb.Parent then
		self._bomb:PivotTo(workspace.Main.Arena.Main:GetPivot() * CFrame.new(0, 5, 0))
		self._bomb.Parent = nil
	end
end

-- Called for the LOCAL player ONLY when they've just been eliminated from a
-- match that had > 2 players before the elimination. Show your LEAVE / RESPAWN UI here.
-- `expirationTime` is the server timestamp when the prompt expires and the
-- server defaults the choice to LEAVE. Use `expirationTime - workspace:GetServerTimeNow()`
-- to drive a countdown on the buttons. The server's clock is
-- the source of truth — if your UI countdown drifts, the server will resolve on
-- its own and OnEliminationChoiceResolved will fire.
-- Use :RequestRespawn() / :RequestLeave() to send the answer.
function RoundController:OnEliminationChoicePrompt(expirationTime: number)
	--
	local ui = self.RespawnUI
	local holder = ui.Holder
	local buttons = holder.Buttons

	PlayerDataController:GetReplica():andThen(function(replica)
		local firstPurchaseOfTheDay = replica.Data.FirstPurchaseOfTheDay or {}
		local firstRespawnOfTheDay = firstPurchaseOfTheDay.Respawn

		buttons.Respawn.DiscountText.Visible = not firstRespawnOfTheDay or firstRespawnOfTheDay <= os.time()
	end)

	HudController:HideHud()
	UIController:OpenFrame(holder, true)

	self._respawnCleaner:Add(UIController:BindButtonClick(buttons.Respawn, function()
		self:RequestRespawn()
	end, true))

	self._respawnCleaner:Add(UIController:BindButtonClick(buttons.Leave, function()
		self:RequestLeave()
	end, true))

	local promptDuration = math.max(0, expirationTime - workspace:GetServerTimeNow())
	self._respawnCleaner:Add(task.spawn(function()
		while true do
			local timeLeft = math.max(0, expirationTime - workspace:GetServerTimeNow())
			local timerAlpha = if promptDuration > 0 then math.clamp(timeLeft / promptDuration, 0, 1) else 0

			if timeLeft <= 0 then
				break
			end

			holder.TimerBar.Bar.Size = UDim2.fromScale(timerAlpha, 1)
			task.wait()
		end
	end))
end

-- Called for the LOCAL player ONLY once the elimination prompt has been
-- resolved (they answered, the timer expired, or the match ended). Hide the
-- LEAVE / RESPAWN UI here. `choice` is "Respawn" or "Leave".
function RoundController:OnEliminationChoiceResolved(choice: string)
	--
	local ui = self.RespawnUI
	local holder = ui.Holder

	if choice == "Respawn" then
		HudController:HideHud()
		self:ToggleGameControls(true)
	else
		HudController:ShowHud()
	end

	UIController:CloseFrame(holder)
	self._respawnCleaner:Clean()
end

-- Called when YOU specifically just received the bomb.
-- Use for: vibrating UI, attaching bomb model client-side, scary SFX, panic
-- shader, showing the pass-direction buttons prominently, etc.
function RoundController:OnReceiveBomb()
	AnimationController:PlayAnimation("HoldBomb")
	self:TogglePassButtons(true)
end

-- Called when ANOTHER player (not you) just received the bomb.
-- `player` is the Player instance (nil if they've already left), `userId` is always present.
-- Use for: highlighting that player's character, playing a pass SFX, updating a
-- bomb-holder nameplate, animating the bomb flying to them, etc.
function RoundController:OnOtherPlayerReceiveBomb(_player: Player?, _userId: number)
	AnimationController:StopAnimation("HoldBomb")
	self:TogglePassButtons(false)
end

-- Called when the server sets a new explosion timer (the music cycle started
-- or resumed). Fires at match start AND after each post-elimination grace when
-- the server begins a new music cycle. `explosionTimestamp` is the absolute
-- server time when the bomb is scheduled to explode — use
-- `explosionTimestamp - workspace:GetServerTimeNow()` for the cycle duration.
-- Use for: starting/resuming music sound, showing the bomb timer UI, etc.
function RoundController:OnMusicStart(_explosionTimestamp: number)
	SoundController:ToggleGameMusic(true, 1)

	if self:IsInMatch() then
		self:ToggleGameControls(true)
	end
end

-- Called when the server clears the explosion timer (the music cycle stopped).
-- Fires on PreElimination, PostElimination, MatchEnd, or any other point where
-- the server stops the music. Use for: fading out music sound, stopping bomb
-- ticking SFX, hiding the bomb timer UI, etc.
function RoundController:OnMusicStop()
	local ui = self.GameUI
	local middle = ui.Middle
	local musicStoppedIcon = middle.MusicStopped

	SoundController:ToggleGameMusic(false, 0)
	SoundController:PlaySound("MusicStop")

	if not self:IsInMatch() then
		return
	end

	-- Tear down any in-flight effects from a previous music stop so threads,
	-- tweens, and the Lighting effect can't stack across cycles.
	self._musicStopCleaner:Clean()

	Spr.target(musicStoppedIcon.UIScale, 0.8, 3, { Scale = 1 })
	musicStoppedIcon:SetAttribute("Speed", 3)
	musicStoppedIcon:SetAttribute("Amplitude", 8)
	musicStoppedIcon:AddTag("UISway")

	self:TogglePassButtons(false)
	self:ToggleGameControls(false)

	-- Red Flash
	local colorCorrection = self._musicStopCleaner:Add(Instance.new("ColorCorrectionEffect"))
	colorCorrection.Parent = Lighting

	TweenService:Create(
		colorCorrection,
		TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut, 0, true),
		{ TintColor = Color3.fromRGB(255, 100, 100) }
	):Play()

	self._musicStopCleaner:Add(task.delay(6, function()
		colorCorrection:Destroy()
	end))

	-- Hide the music stopped icon
	self._musicStopCleaner:Add(task.delay(1.5, function()
		Spr.target(musicStoppedIcon.UIScale, 0.7, 2, { Scale = 0 })
		task.wait(3)

		musicStoppedIcon:RemoveTag("UISway")
		musicStoppedIcon.UIScale.Scale = 0
		musicStoppedIcon.Position = UDim2.fromScale(0.5, 0.5)
	end))

	-- Final reset — runs first on :Clean() (Trove unwinds in reverse), so the
	-- icon ends in a tidy state even if cleanup interrupts the animation
	-- mid-flight (round restart, local player elimination, etc.).
	self._musicStopCleaner:Add(function()
		musicStoppedIcon:RemoveTag("UISway")
		musicStoppedIcon.UIScale.Scale = 0
		musicStoppedIcon.Position = UDim2.fromScale(0.5, 0.5)
	end)
end

function RoundController:OnBombPassed(player: Player, skipAnim: boolean, fromPlayer: Player?)
	--
	local ui = self.GameUI.Top
	local inGame = ui.InGame

	local character = player.Character
	local upperTorso = character.UpperTorso
	local bomb = self._bomb

	TweenService:Create(
		inGame.Title.UIScale,
		TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut, 0, true),
		{ Scale = 1 }
	):Play()

	if not bomb then
		return
	end

	bomb.Parent = workspace.Main

	if fromPlayer and fromPlayer.Character then
		SoundController:PlaySound(
			"OnPass",
			fromPlayer.Character:GetPivot(),
			{ PlaybackSpeed = Random.new():NextNumber(0.9, 1.1) }
		)
	end

	if not skipAnim then
		TweenService:Create(
			bomb,
			TweenInfo.new(0.5, Enum.EasingStyle.Quint),
			{ CFrame = upperTorso:GetPivot() * CFrame.new(0, 0, -2.4) * CFrame.Angles(math.rad(-90), 0, 0) }
		):Play()
	else
		bomb.CFrame = upperTorso:GetPivot() * CFrame.new(0, 0, -2.4) * CFrame.Angles(math.rad(-90), 0, 0)
	end

	if player == LocalPlayer then
		inGame.Title.Text = `<font color="#55ff00">YOU</font> ARE HOLDING THE <font color="#ff0000">BOMB!</font>`
	else
		inGame.Title.Text =
			`<font color="#55ff00">{player.Name:upper()}</font> IS HOLDING THE <font color="#ff0000">BOMB!</font>`
	end

	TweenService:Create(
		inGame.Title.UIScale,
		TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut, 0, true),
		{ Scale = 1.1 }
	):Play()
end

-- Called when the server fires the MatchEnd event (the celebratory phase).
-- `winner` is { UserId, Name, DisplayName } or nil if no one survived.
-- `placements` is the ordered placements table from the server.
-- Use for: confetti VFX, fanfare music, winner podium UI, camera pan to winner, etc.
function RoundController:OnMatchEnd(winner: { [string]: any }?, _placements: { [number]: any })
	--
	local ui = self.GameUI
	local top = ui.Top
	local inGame = top.InGame
	local winnerFrame = top.Winner

	local winnerName = winner and winner.Name or "none"

	-- Reset game ui back to normal
	workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
	Spr.target(inGame, 0.7, 2.5, { Position = UDim2.fromScale(0.5, -0.5) })
	inGame.Title.UIScale.Scale = 1

	self:ToggleGameControls(false)
	HudController:HideHud()
	Controls:Enable()

	self._gameCleaner:Clean()
	self._passCleaner:Clean()
	self._musicStopCleaner:Clean()

	winnerFrame.Title.Text = `{winnerName:upper()} WON!`
	Spr.target(winnerFrame, 0.7, 2.5, { Position = UDim2.fromScale(0.5, 0.1) })

	SoundController:SwitchBGM("Background", 1.5)

	-- Reset per-match state so it doesn't bleed into the next match.
	-- _lastStage is intentionally left alone — it drives stage-change detection
	-- and the upcoming Intermission transition still needs the previous value.
	self._lastBombHolderUserId = nil
	self._explosionTimestamp = 0
	self._countdownEndsAt = 0
	self._bomb = nil
end

----------------------------------------------------------------
-- Internal: waiting dots animation
----------------------------------------------------------------

function RoundController:_stopWaitingDots()
	if self._waitingDotsThread then
		task.cancel(self._waitingDotsThread)
		self._waitingDotsThread = nil
	end
end

----------------------------------------------------------------
-- Internal: intermission countdown loop
----------------------------------------------------------------

function RoundController:_startIntermissionCountdown(endsAt: number)
	if endsAt <= 0 then
		return
	end

	-- Cancel any previously running countdown loop before starting a new one.
	self._countdownEndsAt = endsAt

	task.spawn(function()
		local myEndsAt = endsAt
		while self._lastStage == "Intermission" and self._countdownEndsAt == myEndsAt do
			local rawLeft = math.max(0, myEndsAt - workspace:GetServerTimeNow())
			local secondsLeft = string.format("%05.2f", rawLeft)
			self.OnIntermissionCountdownSignal:Fire(secondsLeft)
			self:OnIntermissionCountdown(secondsLeft)
			if rawLeft <= 0 then
				break
			end
			task.wait()
		end
	end)
end

----------------------------------------------------------------
-- Internal: dispatch hooks based on replica + bridge events
----------------------------------------------------------------

function RoundController:_fireEnterMatchHooks()
	-- Both: shared UI swap, dots cleanup, etc.
	self.OnEnterMatchAllSignal:Fire()
	self:OnEnterMatchAll()

	-- Branch: player vs. spectator.
	-- The server publishes CurrentStage="InitMatch" BEFORE AlivePlayers (each
	-- replica:Set is its own RemoteEvent fire), so on the very frame this hook
	-- runs from the CurrentStage OnChange, AlivePlayers may still be the old
	-- (empty) list — IsInMatch() would then incorrectly report spectator.
	-- task.defer waits until same-frame replica updates have all dispatched.
	task.defer(function()
		if self:IsInMatch() then
			self.OnEnterMatchAsPlayerSignal:Fire()
			self:OnEnterMatchAsPlayer()
		else
			self.OnEnterMatchSpectatorSignal:Fire()
			self:OnEnterMatchSpectator()
		end
	end)
end

function RoundController:_fireStageEntryHooks(newStage: string?, previousStage: string?)
	if newStage == "Intermission" then
		self.OnIntermissionStartedSignal:Fire()
		self:OnIntermissionStart()

		-- Immediately resolve the waiting/countdown state for the current
		-- IntermissionEndsAt value. Handles:
		--   1) Client joins mid-intermission (initial sync).
		--   2) IntermissionEndsAt was already 0 when the stage started, so
		--      the replica fires no OnChange and the waiting hook would never run.
		local endsAt = self._roundReplica and self._roundReplica.Data.IntermissionEndsAt or 0
		if endsAt and endsAt > 0 then
			self:_startIntermissionCountdown(endsAt)
		else
			self.OnIntermissionWaitingSignal:Fire()
			self:OnIntermissionWaiting()
		end
	elseif newStage == "InitMatch" then
		self._countdownEndsAt = 0
		self:_fireEnterMatchHooks()
	elseif newStage == "Match" then
		-- A late joiner who arrives directly in "Match" never saw "InitMatch",
		-- so the OnEnterMatchAll hook (which disables Controls and shows the game
		-- UI) would otherwise be skipped. Fire it here too so the client always
		-- has the in-match setup applied before OnMatchStart runs.
		if previousStage ~= "InitMatch" then
			self:_fireEnterMatchHooks()
		end
		self.OnMatchStartedSignal:Fire()
		self:OnMatchStart()
	end
end

function RoundController:_handleStageChange(newStage: string?)
	if newStage == self._lastStage then
		return
	end

	local previousStage = self._lastStage
	self._lastStage = newStage

	self:_fireStageEntryHooks(newStage, previousStage)
end

function RoundController:_handleBombHolderChange(newHolderUserId: number?)
	if not newHolderUserId then
		self._lastBombHolderUserId = nil
		self:TogglePassButtons(false)
		return
	end

	if newHolderUserId == self._lastBombHolderUserId then
		return
	end

	local previousHolderUserId = self._lastBombHolderUserId
	local holderPlayer = Players:GetPlayerByUserId(newHolderUserId)
	if not holderPlayer then
		self._lastBombHolderUserId = nil
		self:TogglePassButtons(false)
		return
	end
	self._lastBombHolderUserId = newHolderUserId
	local fromPlayer = previousHolderUserId and Players:GetPlayerByUserId(previousHolderUserId) or nil

	if newHolderUserId == LocalPlayer.UserId then
		self.OnReceiveBombSignal:Fire()
		self:OnReceiveBomb()
	elseif newHolderUserId then
		self.OnOtherPlayerReceiveBombSignal:Fire(holderPlayer, newHolderUserId)
		self:OnOtherPlayerReceiveBomb(holderPlayer, newHolderUserId)
	end

	self:OnBombPassed(holderPlayer, false, fromPlayer)
end

----------------------------------------------------------------
-- Lifecycle
----------------------------------------------------------------

function RoundController:OnInit()
	--
	UIController = require(script.Parent.UIController)
	SoundController = require(script.Parent.SoundController)
	HudController = require(script.Parent.HudController)
	AnimationController = require(script.Parent.AnimationController)
	PlayerDataController = require(script.Parent.PlayerDataController)

	--
	self.GameUI = PlayerGui:WaitForChild("GameUI")
	self.RespawnUI = PlayerGui:WaitForChild("RespawnUI")
	self.AbilitiesUI = PlayerGui:WaitForChild("AbilitiesUI")

	--
	Replica.OnNew("RoundData", function(replica)
		self._roundReplica = replica

		self.OnReplicaReady:Fire(replica)

		-- Initial sync (replica may already have data when we attach)
		self:_handleStageChange(replica.Data.CurrentStage)
		self:_handleBombHolderChange(replica.Data.BombHolderUserId)

		replica:OnChange(function(action, path, param1, param2)
			self.OnDataChanged:Fire(action, path, param1, param2, replica.Data)

			-- React to specific replicated keys
			local key = path and path[1]
			if key == "CurrentStage" then
				self:_handleStageChange(replica.Data.CurrentStage)
			elseif key == "BombHolderUserId" then
				self:_handleBombHolderChange(replica.Data.BombHolderUserId)
			elseif key == "IntermissionEndsAt" then
				local endsAt = replica.Data.IntermissionEndsAt or 0
				if self._lastStage == "Intermission" then
					if endsAt > 0 then
						self:_startIntermissionCountdown(endsAt)
					else
						self.OnIntermissionWaitingSignal:Fire()
						self:OnIntermissionWaiting()
					end
				end
			end
		end)
	end)

	--
	UIController:BindButtonClick(self.GameUI.Bottom.Abilities, function()
		UIController:OpenFrame(self.AbilitiesUI.Holder)
	end, true)
end

function RoundController:OnStart()
	-- Server-pushed bomb explosion timestamp
	self.SyncExplosionTimeBridge:Connect(function(payload: any)
		if typeof(payload) == "table" then
			local previousTimestamp = self._explosionTimestamp
			self._explosionTimestamp = payload.Timestamp or 0
			if self._explosionTimestamp > 0 then
				-- Only fire OnMusicStart on a real stopped → playing transition
				-- (mirrors the OnMusicStop guard below). This skips no-op resyncs
				-- where the server pushes the same/updated timestamp without an
				-- intervening clear.
				if previousTimestamp <= 0 then
					self.OnMusicStartSignal:Fire(self._explosionTimestamp)
					self:OnMusicStart(self._explosionTimestamp)
				end
			else
				-- Only fire OnMusicStop on a real playing → stopped transition.
				-- The server may push timestamp=0 at match start or after a previous
				-- stop, and we don't want to re-trigger the hook in those cases.
				if previousTimestamp > 0 and not payload.SuppressMusicStop then
					self.OnMusicStopSignal:Fire()
					self:OnMusicStop()
				end
			end
		end
	end)

	-- Bomb holder broadcast (used for clients who don't watch the replica)
	self.SyncBombHolderBridge:Connect(function(payload: any)
		if typeof(payload) == "table" then
			self:_handleBombHolderChange(payload.UserId)
		end
	end)

	-- Pre-elimination grace (server about to eliminate the victim)
	self.PreEliminationBridge:Connect(function(payload: any)
		if typeof(payload) ~= "table" then
			return
		end
		self.OnPreEliminationSignal:Fire(payload.Victim)
		self:OnPreElimination(payload.Victim)
	end)

	-- Player eliminated broadcast
	self.PlayerEliminatedBridge:Connect(function(payload: any)
		if typeof(payload) ~= "table" then
			return
		end
		self.OnPlayerEliminatedSignal:Fire(payload.Eliminated, payload.RemainingCount)
		self:OnPlayerEliminated(payload.Eliminated, payload.RemainingCount or 0)
	end)

	-- Post-elimination grace (circle about to reset)
	self.PostEliminationBridge:Connect(function(payload: any)
		if typeof(payload) ~= "table" then
			return
		end
		self.OnPostEliminationSignal:Fire(payload.RemainingCount)
		self:OnPostElimination(payload.RemainingCount or 0)
	end)

	-- Elimination choice prompt (server -> this player only)
	self.EliminationChoicePromptBridge:Connect(function(payload: any)
		if typeof(payload) ~= "table" then
			return
		end
		local expirationTime = tonumber(payload.ExpirationTime)
		if not expirationTime then
			local duration = tonumber(payload.DurationSeconds) or 0
			expirationTime = workspace:GetServerTimeNow() + duration
		end
		self.OnEliminationChoicePromptSignal:Fire(expirationTime)
		self:OnEliminationChoicePrompt(expirationTime)
	end)

	-- Elimination choice resolved (server -> this player only)
	self.EliminationChoiceResolvedBridge:Connect(function(payload: any)
		if typeof(payload) ~= "table" then
			return
		end
		local choice = payload.Choice or "Leave"
		self.OnEliminationChoiceResolvedSignal:Fire(choice)
		self:OnEliminationChoiceResolved(choice)
	end)

	-- Match end broadcast (winner + final placements)
	self.MatchEndBridge:Connect(function(payload: any)
		if typeof(payload) ~= "table" then
			return
		end
		self.OnMatchEndSignal:Fire(payload.Winner, payload.Placements)
		self:OnMatchEnd(payload.Winner, payload.Placements)
	end)
end

return RoundController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="466">
            <Properties>
              <string name="Name">SelectPlayerController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local Trove = require(Packages.Trove)

-- Local Player
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

--
local UIController
local RoundController

--
local SelectPlayerController = {
	SyncSelectedPlayer = BridgeNet2.ReferenceBridge("SyncSelectedPlayer"),

	_playerFrames = {},
	_playerFrameCleaners = {},
	_uiCleaner = Trove.new(),
	_roundCleaner = Trove.new(),
	_pendingAbility = nil,
	_selectionCallback = nil,
	_selectedUserId = nil,
}

function SelectPlayerController:OpenUI()
	UIController:OpenFrame(self.UI.Holder)
end

function SelectPlayerController:OpenForAbility(ability: string, onSelected: (number) -> ())
	self._pendingAbility = ability
	self._selectionCallback = onSelected
	self:OpenUI()
end

function SelectPlayerController:CloseUI()
	if not self.UI.Holder.Visible then
		return
	end

	UIController:CloseFrame(self.UI.Holder)
end

function SelectPlayerController:ClearSelection(closeUI: boolean?)
	self._selectedUserId = nil
	self._selectionCallback = nil
	self._pendingAbility = nil

	if closeUI ~= false then
		self:CloseUI()
	end
end

function SelectPlayerController:SelectPlayer(userId: number)
	self._selectedUserId = userId

	local selectionCallback = self._selectionCallback
	self._selectionCallback = nil
	self._pendingAbility = nil
	self:CloseUI()

	if selectionCallback then
		task.spawn(selectionCallback, userId)
	end
end

function SelectPlayerController:_initUI()
	local ui = self.UI
	local holder = ui.Holder
	local container = holder.Container.ScrollingFrame
	local template = container.PlayerFrameTemplate

	template.Visible = false
	self._uiCleaner:Clean()
	for _, frameCleaner in self._playerFrameCleaners do
		frameCleaner:Destroy()
	end
	self._playerFrames = {}
	self._playerFrameCleaners = {}

	local function setPlayerIcon(playerFrame: Frame, userId: number)
		local playerIcon = playerFrame:FindFirstChild("PlayerIcon")
		if not playerIcon or not playerIcon:IsA("ImageLabel") then
			return
		end

		task.spawn(function()
			local success, image = pcall(
				Players.GetUserThumbnailAsync,
				Players,
				userId,
				Enum.ThumbnailType.HeadShot,
				Enum.ThumbnailSize.Size100x100
			)

			if success and self._playerFrames[userId] == playerFrame then
				playerIcon.Image = image
			end
		end)
	end

	local function updatePlayerFrame(playerFrame: Frame, playerInfo: { [string]: any }, layoutOrder: number)
		local userName = playerInfo.Name or "Unknown"
		local displayName = playerInfo.DisplayName or userName

		playerFrame.LayoutOrder = layoutOrder

		local playerDisplayName = playerFrame:FindFirstChild("PlayerDisplayName")
		if playerDisplayName and playerDisplayName:IsA("TextLabel") then
			playerDisplayName.Text = displayName
		end

		local playerUserName = playerFrame:FindFirstChild("PlayerUserName")
		if playerUserName and playerUserName:IsA("TextLabel") then
			playerUserName.Text = `@{userName}`
		end
	end

	local function removePlayerFrame(userId: number)
		local playerFrame = self._playerFrames[userId]
		if not playerFrame then
			return
		end

		local frameCleaner = self._playerFrameCleaners[userId]
		if frameCleaner then
			frameCleaner:Destroy()
			self._playerFrameCleaners[userId] = nil
		end

		playerFrame:Destroy()
		self._playerFrames[userId] = nil
	end

	local function createPlayerFrame(playerInfo: { [string]: any }, userId: number, layoutOrder: number)
		local playerFrame = template:Clone()
		local frameCleaner = Trove.new()

		playerFrame.Name = `PlayerFrame_{userId}`
		playerFrame.Visible = true
		playerFrame.Parent = container

		self._playerFrames[userId] = playerFrame
		self._playerFrameCleaners[userId] = frameCleaner

		updatePlayerFrame(playerFrame, playerInfo, layoutOrder)
		setPlayerIcon(playerFrame, userId)

		frameCleaner:Add(UIController:BindButtonClick(playerFrame.Button, function()
			self:SelectPlayer(userId)
		end, true, false, { ShowFrame = playerFrame }))
	end

	local function isLocalPlayerAlive(alivePlayers: { [number]: { [string]: any } }?): boolean
		for _, playerInfo in alivePlayers or {} do
			if tonumber(playerInfo.UserId) == LocalPlayer.UserId then
				return true
			end
		end

		return false
	end

	local function syncAlivePlayers(alivePlayers: { [number]: { [string]: any } }?)
		local aliveUserIds = {}
		local staleUserIds = {}

		for layoutOrder, playerInfo in alivePlayers or {} do
			local userId = tonumber(playerInfo.UserId)
			if userId then
				if userId == LocalPlayer.UserId then
					continue
				end

				aliveUserIds[userId] = true

				local playerFrame = self._playerFrames[userId]
				if playerFrame then
					updatePlayerFrame(playerFrame, playerInfo, layoutOrder)
				else
					createPlayerFrame(playerInfo, userId, layoutOrder)
				end
			end
		end

		for userId, _playerFrame in self._playerFrames do
			if not aliveUserIds[userId] then
				table.insert(staleUserIds, userId)
			end
		end

		for _, userId in staleUserIds do
			removePlayerFrame(userId)
		end

		if not isLocalPlayerAlive(alivePlayers) then
			self:ClearSelection()
		elseif self._selectedUserId and not aliveUserIds[self._selectedUserId] then
			self:ClearSelection()
		end
	end

	self._uiCleaner:Add(RoundController.OnReplicaReady:Connect(function(replica)
		syncAlivePlayers(replica.Data.AlivePlayers)
	end))

	self._uiCleaner:Add(RoundController.OnDataChanged:Connect(function(_action, path, _param1, _param2, data)
		local key = path and path[1]
		if key == "AlivePlayers" then
			syncAlivePlayers(data.AlivePlayers)
		end
	end))

	self._uiCleaner:Add(Players.PlayerRemoving:Connect(function(player)
		removePlayerFrame(player.UserId)
	end))

	task.spawn(function()
		local data = RoundController:GetData()
		if data then
			syncAlivePlayers(data.AlivePlayers)
		end
	end)
end

function SelectPlayerController:OnInit()
	UIController = require(script.Parent.UIController)
	RoundController = require(script.Parent.RoundController)

	self.UI = PlayerGui:WaitForChild("SelectPlayerUI")
end

function SelectPlayerController:OnStart()
	task.spawn(SelectPlayerController._initUI, self)

	self._roundCleaner:Add(RoundController.OnPlayerEliminatedSignal:Connect(function(eliminatedInfo: { [string]: any }?)
		if not eliminatedInfo then
			return
		end

		if eliminatedInfo.UserId == LocalPlayer.UserId or eliminatedInfo.UserId == self._selectedUserId then
			self:ClearSelection()
		end
	end))

	self._roundCleaner:Add(RoundController.OnMatchEndSignal:Connect(function()
		self:ClearSelection()
	end))

	self._roundCleaner:Add(RoundController.OnIntermissionStartedSignal:Connect(function()
		self:ClearSelection()
	end))

	self.SyncSelectedPlayer:Connect(function(payload: any)
		if typeof(payload) ~= "table" then
			return
		end

		self._selectedUserId = payload.UserId
		if payload.UserId == nil then
			self:ClearSelection()
		end
	end)
end

return SelectPlayerController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="467">
            <Properties>
              <string name="Name">ShopController</string>
              <string name="Source"><![CDATA[-- Services
local MarketplaceService = game:GetService("MarketplaceService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local Spr = require(Packages.Spr)

-- Shared
local Shared = ReplicatedStorage.Shared
local Products = require(Shared.Config.Products)
local Gamepasses = require(Shared.Config.Gamepasses)
local GuiUtil = require(Shared.GuiUtil)

-- Local Player
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

--
local PlayerDataController
local HudController
local UIController
local SoundController

--
local ShopController = {
	--
	RequestProductPurchase = BridgeNet2.ReferenceBridge("RequestProductPurchase"),
	RequestGamepassPurchase = BridgeNet2.ReferenceBridge("RequestGamepassPurchase"),

	--
	Prices = {},
}

-- Requests a product purchase from an id
function ShopController:PromptProductPurchaseFromId(id: string, toGift: Player?): (boolean, { any })
	--
	local productInfo = Products.GetProductFromId(id)
	if not productInfo then
		warn(`Product data for id {id} not found.`)
		return
	end

	--
	self.RequestProductPurchase:Fire({ id, toGift })
	return true, productInfo
end

-- Requests a gamepass purchase from an id
function ShopController:PromptGamepassPurchaseFromId(id: string, toGift: Player): (boolean, { any })
	--
	local gamepassInfo = Gamepasses.GetGamepassFromId(id)
	if not gamepassInfo then
		warn(`Gamepass data for id {id} not found.`)
		return
	end

	--
	self.RequestGamepassPurchase:Fire({ id, toGift })
	return true, gamepassInfo
end

-- Gets the product or gamepass data from an id
function ShopController:GetProductFromId(id: string): Gamepasses.Gamepass | Products.Product
	return Products.GetProductFromId(id) or Gamepasses.GetGamepassFromId(id)
end

-- Gets the price of a product or gamepass
function ShopController:GetPrice(id: string)
	--
	local data = Products.GetProductFromId(id) or Gamepasses.GetGamepassFromId(id)
	if not data then
		return "-"
	end
	local isGamepass = if Products.GetProductFromId(id) then false else true

	--
	if data.CurrencyPrice then
		return data.CurrencyPrice
	end

	--
	if self.Prices[data.Id] then
		return self.Prices[data.Id]
	end

	--
	local success, productInfo = pcall(function()
		return MarketplaceService:GetProductInfo(
			isGamepass and data.PassId or data.ProductId,
			isGamepass and Enum.InfoType.GamePass or Enum.InfoType.Product
		)
	end)

	if not success or not productInfo or productInfo.PriceInRobux == nil then
		return "-"
	end

	local price = productInfo.PriceInRobux
	self.Prices[data.Id] = price

	return price
end

-- Sets up the starter pack UI
function ShopController:_setupStarterPack()
	--
	local holder = self.UI.Holder
	local starterPackContainer = holder.Container.ScrollingFrame.StarterPack

	--
	local purchaseButton = starterPackContainer.Purchase

	task.spawn(function()
		purchaseButton.Title.Text = `{utf8.char(0xE002)}{self:GetPrice("StarterPack")}`
	end)

	UIController:BindButtonClick(purchaseButton, function()
		self:PromptProductPurchaseFromId("StarterPack")
	end, true, false)

	local hudButtonData = HudController:BindHudButton("StarterPack", function()
		self:PromptProductPurchaseFromId("StarterPack")
	end)

	PlayerDataController:GetReplica():andThen(function(replica)
		local starterPackStart = replica.Data.StarterPackStart
		local purchasedOnceProducts = replica.Data.PurchasedOnceProducts

		hudButtonData.Button.Visible = not table.find(purchasedOnceProducts, "StarterPack")
		task.spawn(function()
			while true do
				local timeLeft = starterPackStart - os.time()
				starterPackContainer.Timer.Text = GuiUtil.ConvertSecondsToHHMMSS(timeLeft)
				hudButtonData.Button.Timer.Text = GuiUtil.ConvertSecondsToHHMMSS(timeLeft)

				if timeLeft <= 0 then
					starterPackContainer.Timer.Visible = false
					starterPackContainer.TimerTitle.Visible = false
					hudButtonData.Button.Visible = false
					break
				end

				task.wait(1)
			end
		end)
	end)

	MarketplaceService.PromptProductPurchaseFinished:Connect(function(_, productId: string, wasPurchased: boolean)
		local productData = Products.GetProductFromProductId(productId)
		if productData and productData.Id == "StarterPack" and wasPurchased then
			hudButtonData.Button.Visible = false
			starterPackContainer.Timer.Visible = false
			starterPackContainer.TimerTitle.Visible = false
		end
	end)
end

-- Sets up the gamepasses UI
function ShopController:_setupGamepasses()
	--
	local holder = self.UI.Holder
	local gamepassesContainer = holder.Container.ScrollingFrame.Gamepasses

	--
	for _, gamepassFrame in gamepassesContainer:GetChildren() do
		if not gamepassFrame:IsA("Frame") then
			continue
		end

		local data = Gamepasses.GetGamepassFromId(gamepassFrame.Name)
		if not data then
			print(`Gamepass frame {gamepassFrame.Name} not found in gamepasses data.`)
			continue
		end

		task.spawn(function()
			gamepassFrame.Price.Text = `{utf8.char(0xE002)}{self:GetPrice(data.Id)}`
		end)

		UIController:BindButtonClick(gamepassFrame.Button, function()
			self:PromptGamepassPurchaseFromId(data.Id)
		end, true, false, { ShowFrame = gamepassFrame, ButtonHoverscale = 1.025 })
	end
end

-- Sets up the coins UI
function ShopController:_setupCoins()
	--
	local holder = self.UI.Holder
	local coinsContainer = holder.Container.ScrollingFrame.Coins

	--
	for _, coinFrame in coinsContainer:GetChildren() do
		if not coinFrame:IsA("Frame") then
			continue
		end

		local data = Products.GetProductFromId(coinFrame.Name)
		if not data then
			print(`Coin frame {coinFrame.Name} not found in products data.`)
			continue
		end

		coinFrame.Title.Text = `{data.Value} COINS`
		task.spawn(function()
			coinFrame.Price.Text = `{utf8.char(0xE002)}{self:GetPrice(data.Id)}`
		end)

		UIController:BindButtonClick(coinFrame.Button, function()
			self:PromptProductPurchaseFromId(data.Id)
		end, true, false, { ShowFrame = coinFrame, ButtonHoverscale = 1.025 })
	end
end

--
function ShopController:_setupUI()
	--
	local ui = self.UI
	local holder = ui.Holder

	--
	HudController:BindHudButton("Shop", function()
		UIController:OpenFrame(holder)
	end, true)

	UIController:BindButtonClick(holder.Exit, function()
		UIController:CloseFrame(holder)
	end, true)

	local vignetteThread
	UIController.OnFrameOpened:Connect(function(frame)
		if not (frame == holder) then
			return
		end

		vignetteThread = task.spawn(function()
			while true do
				ui.Glow.ImageTransparency = 0.95 + math.sin(tick() * 3) * 0.05
				task.wait()
			end
		end)

		SoundController:PlaySound("ShopOpen")
		Spr.target(ui.Dim, 0.8, 2.5, { BackgroundTransparency = 0.5 })
	end)

	UIController.OnFrameClosed:Connect(function(frame)
		if not (frame == holder) then
			return
		end

		Spr.target(ui.Dim, 0.8, 2.5, { BackgroundTransparency = 1 })

		if vignetteThread then
			task.cancel(vignetteThread)
		end

		Spr.target(ui.Glow, 0.8, 2.5, { ImageTransparency = 1 })
	end)

	--
	task.spawn(ShopController._setupStarterPack, self)
	task.spawn(ShopController._setupGamepasses, self)
	task.spawn(ShopController._setupCoins, self)
end

function ShopController:OnInit()
	PlayerDataController = require(script.Parent.PlayerDataController)
	UIController = require(script.Parent.UIController)
	HudController = require(script.Parent.HudController)
	SoundController = require(script.Parent.SoundController)

	self.HudUI = PlayerGui:WaitForChild("HudUI")
	self.UI = PlayerGui:WaitForChild("ShopUI")
end

function ShopController:OnStart()
	task.spawn(ShopController._setupUI, self)
end

return ShopController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="468">
            <Properties>
              <string name="Name">SoundController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local SoundService = game:GetService("SoundService")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local TopbarPlus = require(Packages.TopbarPlus)

--
local TIME_THRESHOLD = 0.05

--
local SoundController = {
	PlaySoundEvent = BridgeNet2.ReferenceBridge("PlaySound"),
	PlayRandomSoundEvent = BridgeNet2.ReferenceBridge("PlayRandomSoundInFolder"),
	ReplicateToOthersEvent = BridgeNet2.ReferenceBridge("ReplicateSoundToOthers"),

	_lastPlayedSounds = {},
	_currentGameMusic = nil,
	_muted = false,
}

--
local function createLocationPart(position: Vector3): BasePart
	local locationPart = Instance.new("Part")
	locationPart.Anchored = true
	locationPart.CanCollide = false
	locationPart.Transparency = 1
	locationPart.Size = Vector3.one
	locationPart.Position = position
	locationPart.Parent = workspace.Terrain
	return locationPart
end

-- Plays a sound at a location with optional custom properties
-- @param soundName The name of the sound to play
-- @param location The location to play the sound at (CFrame, Vector3, or Part)
-- @param customProperties Optional custom properties to apply to the sound
-- @param limit Whether to limit overlapping sounds
-- @param replicate Whether to replicate the sound to other clients
-- @returns Sound The sound instance that was played
function SoundController:PlaySound(
	soundName: string,
	location: CFrame | Vector3 | Part?,
	customProperties: { [any]: any }?,
	limit: boolean?,
	replicate: boolean?
): Sound?
	local sound: Sound? = SoundService:FindFirstChild(soundName, true)
	if not sound then
		warn(`Sound {soundName} not found in SoundService`)
		return
	end

	if limit and self._lastPlayedSounds[soundName] then
		return
	end

	local soundClone = sound:Clone()

	if customProperties then
		for property, val in customProperties do
			soundClone[property] = val
		end
	end

	-- Convert CFrame to Vector3 if needed
	if typeof(location) == "CFrame" then
		location = location.Position
	end

	-- Set sound parent based on location type
	local locationPart: BasePart?
	if typeof(location) == "Vector3" then
		locationPart = createLocationPart(location)
		soundClone.Parent = locationPart
	elseif location and location:IsA("BasePart") then
		soundClone.Parent = location
	else
		soundClone.Parent = SoundService.SFX
	end

	if replicate then
		self.ReplicateToOthersEvent:Fire({ soundName, location, customProperties, limit })
	end

	soundClone.Name = `{soundName}_Played`
	soundClone.SoundGroup = SoundService.SFX
	soundClone:Play()

	-- Cleanup sound after it finishes
	task.delay(sound.TimeLength + 1, function()
		if soundClone.Looped then
			return
		end

		if soundClone then
			soundClone:Destroy()
		end

		if locationPart then
			locationPart:Destroy()
		end
	end)

	-- Prevent overlapping sounds
	if limit then
		self._lastPlayedSounds[soundName] = true
		task.delay(TIME_THRESHOLD, function()
			self._lastPlayedSounds[soundName] = nil
		end)
	end

	return soundClone
end

-- Stops a sound with optional fade out
-- @param soundName The name of the sound to stop
-- @param location Optional location to search for the sound (defaults to ReplicatedStorage)
function SoundController:StopSound(soundName: string, location: Instance?)
	local soundLocation = location or ReplicatedStorage
	local sound: Sound? = soundLocation:FindFirstChild(soundName)

	if not sound then
		return
	end

	if sound.Playing then
		local tween = TweenService:Create(sound, TweenInfo.new(1), { Volume = 0 })
		tween:Play()
		tween.Completed:Connect(function()
			if sound then
				sound:Destroy()
			end
		end)
	else
		sound:Destroy()
	end
end

-- Sets the core BGM volume with optional tween duration
-- @param volume The target volume (0-1)
-- @param setDuration Optional duration for the volume tween (default: 0)
function SoundController:SetBGMCoreVolume(volume: number, setDuration: number?)
	local coreBGM = SoundService:FindFirstChild("CoreBGM", true)
	if not coreBGM then
		warn("CoreBGM Sound Group not found in SoundService")
		return
	end

	TweenService:Create(coreBGM, TweenInfo.new(setDuration or 0, Enum.EasingStyle.Linear), {
		Volume = volume,
	}):Play()
end

-- Plays a random sound from a folder
-- @param folderName The name of the folder containing sounds
-- @param params Optional parameters to pass to PlaySound
function SoundController:PlayRandomSoundInFolder(folderName: string, params: { any }?)
	local soundFolder = SoundService:FindFirstChild(folderName, true)
	if not soundFolder then
		warn(`Sound folder {folderName} not found`)
		return
	end

	local sounds = soundFolder:GetChildren()
	if #sounds == 0 then
		warn(`Sound folder {folderName} is empty`)
		return
	end

	local randomSound: Sound = sounds[math.random(1, #sounds)]
	self:PlaySound(randomSound.Name, table.unpack(params or {}))
end

-- Starts the background music cycle
function SoundController:_startBackgroundMusicCycle()
	local backgroundMusic = SoundService:FindFirstChild("BackgroundMusic", true)
	if not backgroundMusic then
		warn("BackgroundMusic Sound Group not found in SoundService")
		return
	end

	while true do
		for _, sound: Sound in backgroundMusic:GetChildren() do
			if not sound:IsA("Sound") then
				continue
			end

			sound:Play()
			sound.Ended:Wait()
		end
		task.wait(1)
	end
end

-- Mutes or unmutes the background music
-- @param toggle Whether to mute (true) or unmute (false)
function SoundController:MuteBGM(toggle: boolean)
	local backgroundMusic = SoundService:FindFirstChild("BackgroundMusic", true)
	if not backgroundMusic then
		warn("BackgroundMusic Sound Group not found in SoundService")
		return
	end

	TweenService:Create(backgroundMusic, TweenInfo.new(1), {
		Volume = toggle and 0 or 1,
	}):Play()
end

-- Turns the game music on or off
-- @param enabled Whether to enable (true) or disable (false) the game music
-- @param fadeDuration Optional duration for the volume fade (default: 1)
function SoundController:ToggleGameMusic(enabled: boolean, fadeDuration: number?)
	local gameMusic = SoundService:FindFirstChild("GameMusic", true)
	if not gameMusic then
		warn("GameMusic Sound Group not found in SoundService")
		return
	end

	TweenService:Create(gameMusic, TweenInfo.new(fadeDuration or 1, Enum.EasingStyle.Linear), {
		Volume = enabled and 1 or 0,
	}):Play()
end

function SoundController:SwitchBGM(bgmType: "Game" | "Background", switchDuration: number?)
	local backgroundMusic = SoundService:FindFirstChild("BackgroundMusic", true)
	local gameMusic = SoundService:FindFirstChild("GameMusic", true)

	TweenService:Create(backgroundMusic, TweenInfo.new(switchDuration or 1, Enum.EasingStyle.Linear), {
		Volume = bgmType == "Background" and 1 or 0,
	}):Play()
	TweenService:Create(gameMusic, TweenInfo.new(switchDuration or 1, Enum.EasingStyle.Linear), {
		Volume = bgmType == "Game" and 1 or 0,
	}):Play()
end

-- Starts the game music thats gonna be used for the match
function SoundController:StartGameMusic(name: string)
	if self._currentGameMusic then
		self._currentGameMusic:Stop()
	end

	local gameMusic = SoundService:FindFirstChild(name, true)
	gameMusic:Play()
	self._currentGameMusic = gameMusic
end

function SoundController:OnInit()
	task.spawn(function()
		self:_startBackgroundMusicCycle()
	end)
end

function SoundController:OnStart()
	-- Setup mute button
	local muteButton = TopbarPlus.new()
	muteButton:setImage("rbxassetid://103265952469825", "Deselected")
	muteButton:setImage("rbxassetid://70577541005282", "Selected")

	muteButton.selected:Connect(function()
		self:MuteBGM(true)
	end)

	muteButton.deselected:Connect(function()
		self:MuteBGM(false)
	end)

	-- Setup event handlers
	self.PlaySoundEvent:Connect(function(data: { any })
		self:PlaySound(table.unpack(data))
	end)

	self.PlayRandomSoundEvent:Connect(function(data: { any })
		self:PlayRandomSoundInFolder(table.unpack(data))
	end)
end

return SoundController
]]></string>
