      <Item class="ModuleScript" referent="382">
        <Properties>
          <string name="Name">GlobalUtil</string>
          <string name="Source"><![CDATA[-- Services
local Players = game:GetService("Players")

--
local GlobalUtil = {}

--
function GlobalUtil.CreateAttachment(part0: BasePart): Attachment
	local attachment = Instance.new("Attachment")
	attachment.Name = "Attachment"
	attachment.Parent = part0

	return attachment
end

-- Gets the first value in the table
function GlobalUtil.Weld(part0: BasePart, part1: BasePart)
	-- Create Weld
	local weldConstraint = Instance.new("WeldConstraint")
	weldConstraint.Part0 = part0
	weldConstraint.Part1 = part1
	weldConstraint.Parent = part0
end

-- Welds the model parts to the model primary part
function GlobalUtil.WeldModel(model: Model, anchorPrimary: boolean?)
	local primaryPart = model.PrimaryPart

	for _, v in model:GetDescendants() do
		if not v:IsA("BasePart") then
			continue
		end

		v.Anchored = false
		GlobalUtil.Weld(primaryPart, v)
	end

	primaryPart.Anchored = anchorPrimary
end

-- Gets all the players in the game
function GlobalUtil.GetAllCharacters(): { Model }
	local characters = {}

	for _, player in Players:GetPlayers() do
		if player.Character then
			table.insert(characters, player.Character)
		end
	end

	return characters
end

function GlobalUtil.ConvertSecondsToHHMMSS(totalSeconds: number): string
	local hours = math.floor(totalSeconds / 3600)
	local minutes = math.floor((totalSeconds % 3600) / 60)
	local seconds = totalSeconds % 60

	return string.format("%02d:%02d:%02d", hours, minutes, seconds)
end

return GlobalUtil
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="383">
        <Properties>
          <string name="Name">GuiUtil</string>
          <string name="Source"><![CDATA[-- Services
local TweenService = game:GetService("TweenService")

-- Constants
local TRANSPARENCY_PROPERTIES = {
	"Transparency",
	"TextTransparency",
	"BackgroundTransparency",
	"ImageTransparency",
	"ScrollBarImageTransparency",
}

local IGNORED_CLASSES = {
	UIGradient = true,
}

local CLEANUP_DELAY = 1
local PULSE_CLEANUP_DELAY = 0.5

local GuiUtil = {}

local activeNumberAnimations = setmetatable({}, { __mode = "k" })

--[[
	Animates a number from 0 to a goal value, calling the callback with each updated value.
	@param goal The target value to animate to
	@param detailed Whether to use NumberValue (true) or IntValue (false)
	@param duration Duration of the animation in seconds
	@param callback Function called with the current value on each update
	@param onFinished Optional function called when animation completes
]]
function GuiUtil.AnimateNumberTo(
	goal: number,
	detailed: boolean,
	duration: number,
	callback: (number) -> (),
	startFrom: number?,
	onFinished: (() -> ())?
)
	local previousAnimation = activeNumberAnimations[callback]
	local startValue = startFrom or 0

	if previousAnimation then
		startValue = previousAnimation.ValueObject.Value
		previousAnimation.Cancelled = true
		previousAnimation.Tween:Cancel()
		previousAnimation.Connection:Disconnect()
		previousAnimation.ValueObject:Destroy()
	end

	local valueObject = detailed and Instance.new("NumberValue") or Instance.new("IntValue")
	valueObject.Value = startValue

	local connection = valueObject:GetPropertyChangedSignal("Value"):Connect(function()
		callback(valueObject.Value)
	end)

	local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
	local tween = TweenService:Create(valueObject, tweenInfo, { Value = goal })
	local animation = {
		Cancelled = false,
		Connection = connection,
		Tween = tween,
		ValueObject = valueObject,
	}

	activeNumberAnimations[callback] = animation

	tween.Completed:Once(function(playbackState)
		if animation.Cancelled or activeNumberAnimations[callback] ~= animation then
			return
		end

		activeNumberAnimations[callback] = nil
		connection:Disconnect()

		if onFinished then
			if playbackState == Enum.PlaybackState.Completed then
				onFinished()
			end
		end

		-- Clean up after a short delay to ensure callback is called
		task.delay(CLEANUP_DELAY, function()
			valueObject:Destroy()
		end)
	end)

	tween:Play()
end

--[[
	Creates a pulse effect on a text label by cloning it and animating scale/transparency.
	@param textLabel The TextLabel to pulse
	@param pulseScale The scale multiplier for the pulse effect
	@param duration Duration of the pulse animation in seconds
]]
function GuiUtil.PulseText(textLabel: TextLabel, pulseScale: number, duration: number)
	local pulseText = textLabel:Clone()
	pulseText.Parent = textLabel.Parent
	pulseText.ZIndex = textLabel.ZIndex - 1

	-- Ensure UIScale exists
	local uiScale = pulseText:FindFirstChildOfClass("UIScale")
	if not uiScale then
		uiScale = Instance.new("UIScale")
		uiScale.Parent = pulseText
	end

	local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)

	-- Animate scale and text transparency
	TweenService:Create(uiScale, tweenInfo, { Scale = pulseScale }):Play()
	TweenService:Create(pulseText, tweenInfo, { TextTransparency = 1 }):Play()

	-- Animate UIStroke if present
	local uiStroke = pulseText:FindFirstChildOfClass("UIStroke")
	if uiStroke then
		TweenService:Create(uiStroke, tweenInfo, { Transparency = 1 }):Play()
	end

	-- Clean up after animation
	task.delay(duration + PULSE_CLEANUP_DELAY, function()
		pulseText:Destroy()
	end)
end

--[[
	Formats a number with comma separators (e.g., 100000 -> "100,000").
	@param amount The number to format
	@return Formatted string with commas
]]
function GuiUtil.ConvertNumberWithCommas(amount: number): string
	local amountStr = tostring(amount)
	-- Reverse, add commas every 3 digits, reverse back, remove leading comma
	return amountStr:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

--[[
	Converts seconds to MM:SS format (e.g., 125 -> "02:05").
	@param totalSeconds Total seconds to convert
	@return Formatted string in MM:SS format
]]
function GuiUtil.ConvertSecondsToMMSS(totalSeconds: number): string
	local minutes = math.floor(totalSeconds / 60)
	local seconds = math.floor(totalSeconds % 60)
	return string.format("%02d:%02d", minutes, seconds)
end

--[[
	Converts seconds to HH:MM:SS format (e.g., 3665 -> "01:01:05").
	@param totalSeconds Total seconds to convert
	@return Formatted string in HH:MM:SS format
]]
function GuiUtil.ConvertSecondsToHHMMSS(totalSeconds: number): string
	local hours = math.floor(totalSeconds / 3600)
	local minutes = math.floor((totalSeconds % 3600) / 60)
	local seconds = math.floor(totalSeconds % 60)
	return string.format("%02d:%02d:%02d", hours, minutes, seconds)
end

--[[
	Converts seconds to a human-readable format, showing only non-zero units (e.g., "2 Secs", "5 Mins, 30 Secs", "2 Days, 03 Hrs").
	@param totalSeconds Total seconds to convert
	@return Human-readable string with only relevant time units
]]
function GuiUtil.ConvertSecondsToHumanReadable(totalSeconds: number): string
	local days = math.floor(totalSeconds / 86400)
	local hours = math.floor((totalSeconds % 86400) / 3600)
	local minutes = math.floor((totalSeconds % 3600) / 60)
	local seconds = math.floor(totalSeconds % 60)

	local parts = {}

	if days > 0 then
		table.insert(parts, string.format("%d Days", days))
	end
	if hours > 0 then
		table.insert(parts, string.format("%02d Hrs", hours))
	end
	if minutes > 0 then
		table.insert(parts, string.format("%02d Mins", minutes))
	end
	if seconds > 0 then
		table.insert(parts, string.format("%02d Secs", seconds))
	end

	-- If all units are zero, show "0 Secs"
	if #parts == 0 then
		return "0 Secs"
	end

	return table.concat(parts, ", ")
end

--[[
	Gets all GUI objects in a container that can have their transparency changed.
	@param container The root GUI object to search
	@return Dictionary mapping GUI objects to their changeable transparency properties
]]
function GuiUtil.GetCanGroupTransparent(container: GuiObject): { [GuiObject]: { string } }
	local result = {}

	--[[
		Gets valid transparency properties for a GUI object.
		@param guiObject The GUI object to check
		@return Array of transparency property names that exist on this object
	]]
	local function getTransparencyProperties(guiObject: GuiObject): { string }
		if IGNORED_CLASSES[guiObject.ClassName] then
			return {}
		end

		local properties = {}
		for _, propertyName in TRANSPARENCY_PROPERTIES do
			local success = pcall(function()
				return guiObject[propertyName]
			end)

			if success then
				table.insert(properties, propertyName)
			end
		end

		return properties
	end

	--[[
		Gets transparency properties that can be changed for a GUI object.
		Handles caching and ignores already-transparent properties.
		@param guiObject The GUI object to check
		@return Array of changeable transparency property names
	]]
	local function getChangeableTransparencyProperties(guiObject: GuiObject): { string }
		local availableProperties = getTransparencyProperties(guiObject)
		local changeableProperties = {}

		for _, propertyName in availableProperties do
			local ignoreAttribute = `Ignore{propertyName}`
			local canChangeAttribute = `CanChange{propertyName}`
			local setAttribute = `Set{propertyName}Transparency`
			local originalAttribute = `Original{propertyName}`

			-- Skip if property is locked
			if guiObject:GetAttribute(ignoreAttribute) then
				continue
			end

			-- Get current or previously set transparency
			local currentTransparency = guiObject:GetAttribute(setAttribute) or guiObject[propertyName]

			-- If already fully transparent and not marked as changeable, lock it
			if currentTransparency == 1 and not guiObject:GetAttribute(canChangeAttribute) then
				guiObject:SetAttribute(ignoreAttribute, true)
				continue
			end

			-- Mark as changeable and store original value if needed
			table.insert(changeableProperties, propertyName)
			guiObject:SetAttribute(canChangeAttribute, true)

			-- Store original transparency value if it's partially transparent
			if
				currentTransparency > 0
				and currentTransparency < 1
				and not guiObject:GetAttribute(originalAttribute)
			then
				guiObject:SetAttribute(originalAttribute, guiObject[propertyName])
			end
		end

		return changeableProperties
	end

	-- Process container itself
	result[container] = getChangeableTransparencyProperties(container)

	-- Process all descendants
	for _, descendant in container:GetDescendants() do
		if not descendant:IsA("GuiObject") then
			continue
		end

		local transparencyProperties = getTransparencyProperties(descendant)
		if #transparencyProperties == 0 then
			continue
		end

		result[descendant] = getChangeableTransparencyProperties(descendant)
	end

	return result
end

--[[
	Sets the transparency of a container and all its descendants that support transparency.
	@param container The root GUI object
	@param transparency Target transparency value (0-1)
	@param timeToTake Duration of the fade animation in seconds
]]
function GuiUtil.SetGroupTransparency(container: GuiObject, transparency: number, timeToTake: number)
	local changeableObjects = GuiUtil.GetCanGroupTransparent(container)
	local tweenInfo = TweenInfo.new(timeToTake, Enum.EasingStyle.Linear)

	for guiObject, transparencyProperties in changeableObjects do
		-- Handle GuiButton visibility based on transparency
		if guiObject:IsA("GuiButton") and not guiObject:GetAttribute("VisibleConnection") then
			local propertyName = if guiObject:IsA("TextButton")
				then "BackgroundTransparency"
				elseif guiObject:IsA("ImageButton") then "ImageTransparency"
				else nil

			if propertyName then
				guiObject:SetAttribute("VisibleConnection", true)
				guiObject:GetPropertyChangedSignal(propertyName):Connect(function()
					guiObject.Visible = guiObject[propertyName] < 1
				end)
			end
		end

		-- Tween each transparency property
		for _, propertyName in transparencyProperties do
			local targetTransparency = if transparency < 1 and guiObject:GetAttribute(`Original{propertyName}`)
				then guiObject:GetAttribute(`Original{propertyName}`)
				else transparency

			TweenService:Create(guiObject, tweenInfo, { [propertyName] = targetTransparency }):Play()
			guiObject:SetAttribute(`Set{propertyName}Transparency`, targetTransparency)
		end
	end
end

return GuiUtil
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="384">
        <Properties>
          <string name="Name">MathUtil</string>
          <string name="Source"><![CDATA[local MathUtil = {}

--
function MathUtil.Lerp(a: number, b: number, t: number): number
	return a + (b - a) * t
end

-- Serializes Vector3
function MathUtil.SerializeVector3(vector3: Vector3): { number }
	return { vector3.X, vector3.Y, vector3.Z }
end

-- Deserializes Vector3
function MathUtil.DeSerializeVector3(serializedVector3: { number }): Vector3
	return Vector3.new(serializedVector3[1], serializedVector3[2], serializedVector3[3])
end

-- Rounds up the raw amount to only get the last 2 decimals
function MathUtil.RoundUpTo2Dec(amount: number): number
	return tonumber(string.format("%.2f", amount))
end

function MathUtil.QuadraticBezier(t, p0, p1, p2)
	return (1 - t) ^ 2 * p0 + 2 * (1 - t) * t * p1 + t ^ 2 * p2
end

return MathUtil
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="385">
        <Properties>
          <string name="Name">RagdollShared</string>
          <string name="Source"><![CDATA[-- Services
local CollectionService = game:GetService("CollectionService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

--
local RagdollShared = {}
RagdollShared.BRIDGE_NAME = "RagdollPlayer"
RagdollShared.VALID_HUMANOID_STATES = {
	[Enum.HumanoidStateType.Physics] = true,
	[Enum.HumanoidStateType.Dead] = true,
}

export type RagdollPayload = {
	Toggle: boolean,
	TimeLength: number?,
	PushDirection: Vector3?,
}

local function hasRagdollOwnership(humanoid: Humanoid)
	if RunService:IsServer() then
		-- Always set on the server, even if the owning client has already
		-- toggled the ragdoll. We don't want the server to be desynced in
		-- case the character changes ownership
		return true
	end

	local player = Players:GetPlayerFromCharacter(humanoid.Parent)
	return player == Players.LocalPlayer
end

function RagdollShared._toggleRagdoll(character: Model, toggle: boolean)
	--
	local ragdollConstraints = character:FindFirstChild("RagdollConstraints")
	if not ragdollConstraints then
		return
	end

	local player = Players:GetPlayerFromCharacter(character)
	if player then
		if toggle then
			player:AddTag("Ragdoll")
		else
			player:RemoveTag("Ragdoll")
		end
	end

	character.Animate.Enabled = not toggle

	for _, constraint in ragdollConstraints:GetChildren() do
		if not constraint:IsA("Constraint") then
			continue
		end

		local rigidJoint = constraint.RigidJoint.Value
		local expectedValue = (not toggle) and constraint.Attachment1.Parent or nil

		if rigidJoint.Part1 ~= expectedValue then
			rigidJoint.Part1 = expectedValue
		end
	end
end

function RagdollShared.EnableRagdoll(character: Model)
	local humanoid = character.Humanoid

	if not hasRagdollOwnership(humanoid) then
		return
	end

	local player = Players:GetPlayerFromCharacter(character)
	if player and player:HasTag("Ragdoll") then
		return
	end

	RagdollShared._toggleRagdoll(character, true)
end

function RagdollShared.DisableRagdoll(character: Model)
	local humanoid = character.Humanoid

	if not hasRagdollOwnership(humanoid) then
		return
	end

	RagdollShared._toggleRagdoll(character, false)
end

return RagdollShared
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="386">
        <Properties>
          <string name="Name">RandomUtil</string>
          <string name="Source"><![CDATA[local RandomUtil = {}

--[[
	Selects a random item from weighted data.
	@param data Array of {value, weight} pairs, e.g., { {"Common", 20}, {"Rare", 5} }
	@param seed Optional seed for the random number generator
	@return The selected value and the full entry {value, weight}
]]
function RandomUtil.GetResultFromWeight(data: { table }, seed: number?)
	local totalWeight = 0
	for _, entry in data do
		totalWeight += entry[2]
	end

	if totalWeight <= 0 then
		return nil, nil
	end

	local rng = Random.new(seed or tick())
	local chosen = rng:NextNumber(0, totalWeight)

	local accumulatedWeight = 0
	for _, entry in data do
		accumulatedWeight += entry[2]
		if chosen <= accumulatedWeight then
			return entry[1], entry
		end
	end

	-- Fallback (should never reach here)
	return data[#data][1], data[#data]
end

--[[
	Gets a random value from the data table.
	If the value is in the ignoreList, it will retry up to 10 times.
	@param data Array of values to choose from
	@param ignoreList Single value or array of values to exclude
	@return Random value not in ignoreList, or nil if all attempts failed
]]
function RandomUtil.GetRandomFromArray(data: { any }, ignoreList: any?): any?
	if #data == 0 then
		return nil
	end

	local rng = Random.new()
	local maxAttempts = 10

	for attempt = 1, maxAttempts do
		local randomIndex = rng:NextInteger(1, #data)
		local currentRandom = data[randomIndex]

		-- Check if value should be ignored
		local shouldIgnore = false
		if ignoreList then
			if typeof(ignoreList) == "table" then
				shouldIgnore = table.find(ignoreList, currentRandom) ~= nil
			else
				shouldIgnore = ignoreList == currentRandom
			end
		end

		if not shouldIgnore then
			return currentRandom
		end
	end

	return nil
end

--[[
	Gets a random point on the part, constrained to the XZ plane (Y = 0).
	@param part The part to sample from
	@return A random Vector3 position on the part's XZ plane
]]
function RandomUtil.GetRandomXZFromPart(part: BasePart): Vector3
	local partSize = part.Size
	local rng = Random.new()
	local randomOffset =
		Vector3.new(rng:NextNumber(-partSize.X / 2, partSize.X / 2), 0, rng:NextNumber(-partSize.Z / 2, partSize.Z / 2))
	return (part.CFrame * CFrame.new(randomOffset)).Position
end

--[[
	Gets a random point anywhere within the part's bounds.
	@param part The part to sample from
	@return A random Vector3 position within the part
]]
function RandomUtil.GetRandomXYZFromPart(part: BasePart): Vector3
	local partSize = part.Size
	local rng = Random.new()
	local randomOffset = Vector3.new(
		rng:NextNumber(-partSize.X / 2, partSize.X / 2),
		rng:NextNumber(-partSize.Y / 2, partSize.Y / 2),
		rng:NextNumber(-partSize.Z / 2, partSize.Z / 2)
	)
	return (part.CFrame * CFrame.new(randomOffset)).Position
end

--[[
	Gets a random number between min and max (inclusive).
	@param min Minimum value
	@param max Maximum value
	@param seed Optional seed for the random number generator
	@return Random number in range [min, max)
]]
function RandomUtil.GetRandomFromMinMax(min: number, max: number, seed: number?): number
	local rng = Random.new(seed or tick())
	return rng:NextNumber(min, max)
end

--[[
	Gets a random integer between min and max (inclusive).
	@param min Minimum value
	@param max Maximum value
	@param seed Optional seed for the random number generator
	@return Random integer in range [min, max]
]]
function RandomUtil.GetRandomIntFromMinMax(min: number, max: number, seed: number?): number
	local rng = Random.new(seed or tick())
	return rng:NextInteger(min, max)
end

--[[
	Returns true with the given percentage chance.
	@param chance Percentage chance (0-100) to return true
	@param seed Optional seed for the random number generator
	@return true if chance succeeds, false otherwise
]]
function RandomUtil.RollChance(chance: number, seed: number?): boolean
	local rng = Random.new(seed or tick())
	return rng:NextNumber(0, 100) < chance
end

return RandomUtil
]]></string>
        </Properties>
      </Item>
    </Item>
  </Item>
  <Item class="ServerScriptService" referent="387">
    <Properties>
      <string name="Name">ServerScriptService</string>
    </Properties>
    <Item class="Folder" referent="388">
      <Properties>
        <string name="Name">Server</string>
      </Properties>
      <Item class="Folder" referent="389">
        <Properties>
          <string name="Name">Components</string>
        </Properties>
      </Item>
      <Item class="Folder" referent="390">
        <Properties>
          <string name="Name">Managers</string>
        </Properties>
        <Item class="ModuleScript" referent="391">
          <Properties>
            <string name="Name">AbilitiesManager</string>
            <string name="Source"><![CDATA[-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local AnalyticsService = game:GetService("AnalyticsService")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)

-- Abilities
local AbilitiesModules = ReplicatedStorage.Shared.Abilities

--
local NotificationManager
local PlayerDataManager
local ShopManager
local CurrencyManager
local RoundManager
local SelectPlayerManager

local REQUEST_THROTTLE_SECONDS = 0.35
local REQUEST_THROTTLE_NOTIFY_SECONDS = 1.5
local DEFAULT_ABILITY_COOLDOWN_SECONDS = 3
local MIN_ABILITY_COOLDOWN_SECONDS = 1

--
local AbilitiesManager = {
	UseAbilityEvent = BridgeNet2.ReferenceBridge("UseAbility"),
	OnUseAbilityEvent = BridgeNet2.ReferenceBridge("OnUseAbility"),
	RequestAbilityPurchaseEvent = BridgeNet2.ReferenceBridge("RequestAbilityPurchase"),
	RequestPurchaseAbilityWithCurrencyEvent = BridgeNet2.ReferenceBridge("RequestPurchaseAbilityWithCurrency"),

	_abilities = {},
	_cooldowns = {},
	_requestLocks = {},
	_requestTimestamps = {},
	_requestNotifyTimestamps = {},
}

----------------------------------------------------------------
-- Local Helpers
----------------------------------------------------------------

local function isValidPlayer(player: Player?): boolean
	return player ~= nil and player:IsDescendantOf(Players)
end

local function getAbilityName(ability: string, config: { [string]: any }): string
	return config.Name or ability
end

local function notify(playerOrPlayers: any, text: string, notificationType: string?)
	NotificationManager.NotifyNormalEvent:Fire(playerOrPlayers, {
		text,
		nil,
		notificationType,
	})
end

local function logCurrencySink(player: Player, ability: string, price: number)
	task.spawn(function()
		pcall(function()
			PlayerDataManager:GetPlayerDataKey(player, "Currency"):andThen(function(currency)
				AnalyticsService:LogEconomyEvent(
					player,
					Enum.AnalyticsEconomyFlowType.Sink,
					"Coins",
					price,
					currency,
					Enum.AnalyticsEconomyTransactionType.Shop.Name,
					ability
				)
			end)
		end)
	end)
end

local function getCooldownKey(player: Player, ability: string): string
	return `{player.UserId}_{ability}`
end

local function getCooldownLeft(cooldowns: { [string]: number }, player: Player, ability: string): number
	local cooldownEndsAt = cooldowns[getCooldownKey(player, ability)] or 0
	return math.max(0, cooldownEndsAt - workspace:GetServerTimeNow())
end

local function getAbilityCooldown(abilityConfig: { [string]: any }): number
	local cooldown = abilityConfig.Cooldown
	if type(cooldown) ~= "number" then
		return DEFAULT_ABILITY_COOLDOWN_SECONDS
	end

	return math.max(MIN_ABILITY_COOLDOWN_SECONDS, cooldown)
end

local function parseAbilityPayload(abilityPayload: any, selectedTargetPayload: any?): (string?, any?)
	if type(abilityPayload) == "string" then
		return abilityPayload, selectedTargetPayload
	end

	if type(abilityPayload) ~= "table" then
		return nil, selectedTargetPayload
	end

	return abilityPayload.Ability, selectedTargetPayload or abilityPayload.SelectedUserId
end

local function prepareSelectedPlayer(
	player: Player,
	abilityConfig: { [string]: any },
	selectedTargetPayload: any?
): boolean
	if not abilityConfig.SelectPlayer then
		return true
	end

	if selectedTargetPayload == nil then
		return true
	end

	return SelectPlayerManager:SetSelectedPlayerByUserId(player, selectedTargetPayload)
end

local function cleanupPlayerRequests(self, player: Player)
	self._requestLocks[player] = nil
	self._requestTimestamps[player] = nil
	self._requestNotifyTimestamps[player] = nil
end

local function cleanupPlayerCooldowns(self, player: Player)
	local playerPrefix = `{player.UserId}_`

	for key in self._cooldowns do
		if string.sub(key, 1, #playerPrefix) == playerPrefix then
			self._cooldowns[key] = nil
		end
	end
end

local function tryBeginPlayerRequest(self, player: Player): boolean
	if not isValidPlayer(player) then
		return false
	end

	if self._requestLocks[player] then
		return false
	end

	local now = workspace:GetServerTimeNow()
	local nextAllowedRequest = (self._requestTimestamps[player] or 0) + REQUEST_THROTTLE_SECONDS
	if now < nextAllowedRequest then
		local nextNotify = self._requestNotifyTimestamps[player] or 0
		if now >= nextNotify then
			self._requestNotifyTimestamps[player] = now + REQUEST_THROTTLE_NOTIFY_SECONDS
			notify(player, "Please wait a moment before using another ability.", "Reject")
		end

		return false
	end

	self._requestTimestamps[player] = now
	self._requestLocks[player] = true
	return true
end

local function finishPlayerRequest(self, player: Player)
	self._requestLocks[player] = nil
end

----------------------------------------------------------------
-- Public API
----------------------------------------------------------------

-- Adds owned uses to a player's ability inventory. This is used for shop
-- purchases outside the match and for Robux purchases that should stack.
function AbilitiesManager:AddPlayerAbility(player: Player, ability: string, amount: number?)
	if not isValidPlayer(player) then
		return
	end

	local hasData, playerData = PlayerDataManager:GetPlayerData(player):await()
	if not hasData then
		return
	end

	local abilities = playerData.Abilities or {}
	abilities[ability] = (abilities[ability] or 0) + (amount or 1)
	PlayerDataManager:SetPlayerDataKey(player, "Abilities", abilities)
end

-- Handles the client "use ability" request. If the player owns a use, it
-- spends one and runs in the active match; if they own none, it routes to the
-- configured currency or Robux purchase path.
function AbilitiesManager:UseAbility(player: Player, abilityPayload: any, selectedTargetPayload: any?)
	if not tryBeginPlayerRequest(self, player) then
		return
	end

	local ok, err = xpcall(function()
		local ability, parsedTargetPayload = parseAbilityPayload(abilityPayload, selectedTargetPayload)
		if type(ability) ~= "string" or not isValidPlayer(player) then
			return
		end

		local abilityEntry = self._abilities[ability]
		if not abilityEntry then
			warn(`Ability '{ability}' not found.`)
			return
		end

		local abilityConfig = abilityEntry.Config
		local hasData, playerData = PlayerDataManager:GetPlayerData(player):await()
		if not hasData then
			return
		end

		local abilities = playerData.Abilities or {}
		local ownedAmount = abilities[ability] or 0
		local isInActiveMatch = RoundManager:IsPlayerInActiveMatch(player)

		if isInActiveMatch then
			local cooldownLeft = getCooldownLeft(self._cooldowns, player, ability)
			if cooldownLeft > 0 then
				notify(
					player,
					`Wait <font color="#ff0000">{string.format("%.2f", cooldownLeft)}</font> seconds before using <font color="#55ff00">{getAbilityName(
						ability,
						abilityConfig
					)}</font> again!`,
					"Reject"
				)
				return
			end
		end

		if ownedAmount <= 0 then
			if abilityConfig.IsCurrencyPurchase then
				self:_purchaseAbilityWithCurrency(player, ability, isInActiveMatch, parsedTargetPayload)
			elseif abilityConfig.IsRobuxPurchase then
				if not prepareSelectedPlayer(player, abilityConfig, parsedTargetPayload) then
					return
				end

				ShopManager:AttemptProductPurchase(player, ability)
			else
				notify(
					player,
					`<font color="#ffd400">{getAbilityName(ability, abilityConfig)}</font> is not available for purchase.`,
					"Reject"
				)
			end
			return
		end

		if not isInActiveMatch then
			notify(player, "Abilities can only be used while you are alive in a match.", "Reject")
			return
		end

		if not prepareSelectedPlayer(player, abilityConfig, parsedTargetPayload) then
			return
		end

		if self:_runAbility(player, ability, abilityEntry) then
			abilities[ability] = math.max(0, ownedAmount - 1)
			PlayerDataManager:SetPlayerDataKey(player, "Abilities", abilities)
		end
	end, debug.traceback)

	finishPlayerRequest(self, player)

	if not ok then
		warn(`Failed to use ability: {err}`)
	end
end

-- Legacy-friendly helper for code paths that expect an immediate currency
-- purchase and use attempt.
function AbilitiesManager:PurchaseThenUseAbility(player: Player, ability: string, selectedTargetPayload: any?)
	if not tryBeginPlayerRequest(self, player) then
		return
	end

	local ok, err = xpcall(function()
		self:_purchaseAbilityWithCurrency(player, ability, true, selectedTargetPayload)
	end, debug.traceback)

	finishPlayerRequest(self, player)

	if not ok then
		warn(`Failed to purchase then use ability: {err}`)
	end
end

-- Purchases an ability with in-game currency. Active alive players auto-use
-- the purchase immediately; players outside the match receive one owned use.
function AbilitiesManager:PurchaseAbilityWithCurrency(player: Player, abilityPayload: any, selectedTargetPayload: any?)
	if not tryBeginPlayerRequest(self, player) then
		return
	end

	local ok, err = xpcall(function()
		local ability, parsedTargetPayload = parseAbilityPayload(abilityPayload, selectedTargetPayload)
		if type(ability) ~= "string" then
			return
		end

		self:_purchaseAbilityWithCurrency(
			player,
			ability,
			RoundManager:IsPlayerInActiveMatch(player),
			parsedTargetPayload
		)
	end, debug.traceback)

	finishPlayerRequest(self, player)

	if not ok then
		warn(`Failed to purchase ability with currency: {err}`)
	end
end

-- Client-facing adaptive purchase path. Outside an active match this buys and
-- stores a use; inside an active match it buys and immediately uses it.
function AbilitiesManager:PurchaseAbility(player: Player, abilityPayload: any, selectedTargetPayload: any?)
	if not tryBeginPlayerRequest(self, player) then
		return
	end

	local ok, err = xpcall(function()
		local ability, parsedTargetPayload = parseAbilityPayload(abilityPayload, selectedTargetPayload)
		if type(ability) ~= "string" or not isValidPlayer(player) then
			return
		end

		local abilityEntry = self._abilities[ability]
		if not abilityEntry then
			warn(`Ability '{ability}' not found.`)
			return
		end

		local abilityConfig = abilityEntry.Config
		if abilityConfig.IsCurrencyPurchase then
			self:_purchaseAbilityWithCurrency(
				player,
				ability,
				RoundManager:IsPlayerInActiveMatch(player),
				parsedTargetPayload
			)
		elseif abilityConfig.IsRobuxPurchase then
			if not prepareSelectedPlayer(player, abilityConfig, parsedTargetPayload) then
				return
			end

			ShopManager:AttemptProductPurchase(player, ability)
		else
			notify(
				player,
				`<font color="#ffd400">{getAbilityName(ability, abilityConfig)}</font> is not available for purchase.`,
				"Reject"
			)
		end
	end, debug.traceback)

	finishPlayerRequest(self, player)

	if not ok then
		warn(`Failed to purchase ability: {err}`)
	end
end

----------------------------------------------------------------
-- Internal Flow
----------------------------------------------------------------

function AbilitiesManager:_runAbility(player: Player, ability: string, abilityEntry: { [string]: any }): boolean
	if not RoundManager:IsPlayerInActiveMatch(player) then
		notify(player, "Abilities can only be used while you are alive in a match.", "Reject")
		return false
	end

	local alivePlayers = RoundManager:GetAlivePlayers()
	if #alivePlayers == 0 then
		return false
	end

	local abilityConfig = abilityEntry.Config
	local selectedPlayer = nil
	if abilityConfig.SelectPlayer then
		selectedPlayer = SelectPlayerManager:ConsumeSelectedPlayer(player)
		if not selectedPlayer then
			notify(player, "Select a target player first.", "Reject")
			return false
		end
	end

	local result = abilityEntry.Server(player, alivePlayers, {
		Ability = ability,
		Config = abilityConfig,
		RoundManager = RoundManager,
		SelectPlayerManager = SelectPlayerManager,
		SelectedPlayer = selectedPlayer,
	})
	if result == false then
		return false
	end

	local cooldown = getAbilityCooldown(abilityConfig)
	local cooldownEndsAt = workspace:GetServerTimeNow() + cooldown
	self._cooldowns[getCooldownKey(player, ability)] = cooldownEndsAt

	self.UseAbilityEvent:Fire(BridgeNet2.Players(alivePlayers), { ability, "Victim" })
	self.UseAbilityEvent:Fire(player, { ability, "Activator" })
	self.OnUseAbilityEvent:Fire(player, { ability, cooldownEndsAt })

	notify(
		BridgeNet2.Players(alivePlayers),
		`<font color="#55ff00">{player.Name}</font> Used <font color="#ff0000">{getAbilityName(ability, abilityConfig)}</font>`
	)
	return true
end

function AbilitiesManager:_purchaseAbilityWithCurrency(
	player: Player,
	ability: string,
	shouldAutoUse: boolean,
	selectedTargetPayload: any?
): boolean
	if not isValidPlayer(player) then
		return false
	end

	local abilityEntry = self._abilities[ability]
	if not abilityEntry then
		warn(`Ability '{ability}' not found.`)
		return false
	end

	local abilityConfig = abilityEntry.Config
	if not abilityConfig.IsCurrencyPurchase then
		notify(
			player,
			`<font color="#ffd400">{getAbilityName(ability, abilityConfig)}</font> cannot be purchased with Bux.`,
			"Reject"
		)
		return false
	end

	local price = abilityConfig.Price
	if type(price) ~= "number" or price <= 0 then
		warn(`Ability '{ability}' has no valid currency price configured.`)
		return false
	end

	local canAfford, currencyNeeded = CurrencyManager:CanAfford(player, price)
	if not canAfford then
		currencyNeeded = currencyNeeded or price
		notify(
			player,
			`You need <font color="#2de200">{currencyNeeded} Bux</font> more to purchase <font color="#ffd400">{getAbilityName(
				ability,
				abilityConfig
			)}</font>`,
			"Reject"
		)
		ShopManager:PromptCurrencyPurchase(player, currencyNeeded)
		return false
	end

	if shouldAutoUse and RoundManager:IsPlayerInActiveMatch(player) then
		local cooldownLeft = getCooldownLeft(self._cooldowns, player, ability)
		if cooldownLeft > 0 then
			notify(
				player,
				`Wait <font color="#ff0000">{string.format("%.2f", cooldownLeft)}</font> seconds before using <font color="#55ff00">{getAbilityName(
					ability,
					abilityConfig
				)}</font> again!`,
				"Reject"
			)
			return false
		end

		if not prepareSelectedPlayer(player, abilityConfig, selectedTargetPayload) then
			return false
		end

		if not self:_runAbility(player, ability, abilityEntry) then
			return false
		end
	else
		self:AddPlayerAbility(player, ability)
		notify(
			player,
			`Successfully purchased <font color="#ffd400">{getAbilityName(ability, abilityConfig)}</font>`,
			"CurrencyPurchase"
		)
	end

	CurrencyManager:DeductCurrency(player, price)
	logCurrencySink(player, ability, price)
	return true
end

function AbilitiesManager:_handleRobuxAbilityPurchased(player: Player, ability: string)
	local abilityEntry = self._abilities[ability]
	if not abilityEntry or not abilityEntry.Config.IsRobuxPurchase then
		return
	end

	if RoundManager:IsPlayerInActiveMatch(player) then
		local cooldownLeft = getCooldownLeft(self._cooldowns, player, ability)
		if cooldownLeft <= 0 and self:_runAbility(player, ability, abilityEntry) then
			return
		end

		notify(
			player,
			`<font color="#ffd400">{getAbilityName(ability, abilityEntry.Config)}</font> was added to your inventory.`,
			"RobuxPurchase"
		)
		self:AddPlayerAbility(player, ability)
	else
		self:AddPlayerAbility(player, ability)
	end
end

----------------------------------------------------------------
-- Lifecycle
----------------------------------------------------------------

-- Loads manager dependencies and discovers every ability module under
-- ReplicatedStorage.Shared.Abilities.
function AbilitiesManager:OnInit()
	NotificationManager = require(script.Parent.NotificationManager)
	PlayerDataManager = require(script.Parent.PlayerDataManager)
	ShopManager = require(script.Parent.ShopManager)
	CurrencyManager = require(script.Parent.CurrencyManager)
	RoundManager = require(script.Parent.RoundManager)
	SelectPlayerManager = require(script.Parent.SelectPlayerManager)

	for _, ability in AbilitiesModules:GetChildren() do
		self._abilities[ability.Name] = {
			Server = require(ability.Server),
			Config = require(ability.Config),
		}
	end
end

-- Connects client bridge requests and Robux purchase completion callbacks.
function AbilitiesManager:OnStart()
	self.UseAbilityEvent:Connect(function(player: Player, abilityPayload: any)
		self:UseAbility(player, abilityPayload)
	end)

	self.RequestAbilityPurchaseEvent:Connect(function(player: Player, abilityPayload: any)
		self:PurchaseAbility(player, abilityPayload)
	end)

	self.RequestPurchaseAbilityWithCurrencyEvent:Connect(function(player: Player, abilityPayload: any)
		self:PurchaseAbilityWithCurrency(player, abilityPayload)
	end)

	ShopManager.PlayerPurchased:Connect(function(player: Player, productId: string)
		self:_handleRobuxAbilityPurchased(player, productId)
	end)

	Players.PlayerRemoving:Connect(function(player: Player)
		cleanupPlayerRequests(self, player)
		cleanupPlayerCooldowns(self, player)
	end)
end

return AbilitiesManager
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="392">
          <Properties>
            <string name="Name">BadgeManager</string>
            <string name="Source"><![CDATA[-- Services
local BadgeService = game:GetService("BadgeService")

-- Modules
local Badges
local NotificationManager

local BadgeManager = {
	_playerBadges = {},
}

--[=[
	Initializes the player's badge cache table if it doesn't exist.

	@param player Player -- The player to initialize the cache for.
	@private
]=]
function BadgeManager:_ensurePlayerCache(player: Player)
	if not self._playerBadges[player] then
		self._playerBadges[player] = {}
	end
end

--[=[
	Checks if a player has a specific badge via BadgeService.

	@param userId number -- The user ID to check.
	@param badgeId number -- The badge ID to check.
	@return boolean -- Whether the check was successful.
	@return boolean -- Whether the user has the badge.
	@private
]=]
function BadgeManager:_checkBadgeOwnership(userId: number, badgeId: number): (boolean, boolean)
	local success, hasBadge = pcall(function()
		return BadgeService:UserHasBadgeAsync(userId, badgeId)
	end)

	return success, hasBadge
end

--[=[
	Awards a badge to the specified player if they have not already received it.

	@param player Player -- The player to award the badge to.
	@param badgeKey string -- The key of the badge to be awarded.
	@param dontAnnounce boolean? -- Whether to skip the notification announcement.
	@return boolean -- Whether the badge was successfully awarded.
]=]
function BadgeManager:AwardBadge(player: Player, badgeKey: string, dontAnnounce: boolean?): boolean
	local badgeData = Badges.GetBadgeFromKey(badgeKey)
	if not badgeData then
		warn(`BadgeManager:AwardBadge -> Badge key "{badgeKey}" does not exist in config!`)
		return false
	end

	self:_ensurePlayerCache(player)

	-- Check if already cached as having the badge
	if self._playerBadges[player][badgeKey] then
		return false
	end

	-- Verify badge ownership via BadgeService
	local success, hasBadge = self:_checkBadgeOwnership(player.UserId, badgeData.BadgeId)
	if not success then
		warn(`BadgeManager:AwardBadge -> Failed to check badge ownership for player {player.Name} (Badge: {badgeKey})`)
		return false
	end

	if hasBadge then
		self._playerBadges[player][badgeKey] = true
		return false
	end

	-- Award the badge
	local awardSuccess, errorMessage = pcall(function()
		BadgeService:AwardBadge(player.UserId, badgeData.BadgeId)
	end)

	if not awardSuccess then
		warn(`BadgeManager:AwardBadge -> Failed to award badge to {player.Name}: {errorMessage}`)
		return false
	end

	-- Cache and notify
	self._playerBadges[player][badgeKey] = true

	if not dontAnnounce then
		NotificationManager.NotifyNormalEvent:Fire(
			player,
			{ `Badge <font color="#ffd400">{badgeData.Name}</font> Unlocked!` }
		)
	end

	return true
end

--[=[
	Checks if a player has a specific badge (cached check only).

	@param player Player -- The player to check.
	@param badgeKey string -- The key of the badge to check.
	@return boolean -- Whether the player has the badge.
]=]
function BadgeManager:PlayerHasBadge(player: Player, badgeKey: string): boolean
	local playerCache = self._playerBadges[player]
	return playerCache ~= nil and playerCache[badgeKey] == true
end

--[=[
	Caches all badges that the specified player has already received.

	@param player Player -- The player whose badges are to be cached.
	@private
]=]
function BadgeManager:_cachePlayerBadges(player: Player)
	self:_ensurePlayerCache(player)

	local function cacheBadge(badgeData: Badges.Badge)
		local success, hasBadge = self:_checkBadgeOwnership(player.UserId, badgeData.BadgeId)

		if success and hasBadge then
			self._playerBadges[player][badgeData.Key] = true
		end
	end

	-- Cache all badges asynchronously
	for _, badge: Badges.Badge in Badges.GetBadges() do
		task.spawn(cacheBadge, badge)
	end
end

--[=[
	Handles when a player joins the game.

	@param player Player -- The player who joined.
]=]
function BadgeManager:OnPlayerAdded(player: Player)
	self._playerBadges[player] = {}
	self:_cachePlayerBadges(player)
end

--[=[
	Handles when a player leaves the game.

	@param player Player -- The player who left.
]=]
function BadgeManager:OnPlayerRemoving(player: Player)
	self._playerBadges[player] = nil
end

--[=[
	Initializes the BadgeManager and sets up badge listeners.
]=]
function BadgeManager:OnInit()
	NotificationManager = require(script.Parent.NotificationManager)
	Badges = require(script.Badges)

	-- Initialize badge listeners
	for _, badge: Badges.Badge in Badges.GetBadges() do
		if not badge.OnInitCallback then
			continue
		end

		badge.OnInitCallback(function(player: Player, badgeKey: string, announce: boolean?)
			if self:PlayerHasBadge(player, badgeKey) then
				return
			end

			self:AwardBadge(player, badgeKey, announce)
		end)
	end
end

function BadgeManager:OnStart() end

return BadgeManager
]]></string>
          </Properties>
          <Item class="ModuleScript" referent="393">
            <Properties>
              <string name="Name">Badges</string>
              <string name="Source"><![CDATA[--[[ 
	OnInitCallback: This function runs when the BadgeService is initialized.
	It is best to attach listeners in this function. (SHOULD ONLY BE CALLED ONCE!!!) 
--]]

--[[
	toAwardCallback: This function should be called when the condition for awarding
	the badge is met on your listener. It will give the badge to the player.
--]]

export type Badge = {
	Name: string,
	Key: string,
	BadgeId: number,
	OnInitCallback: (toAwardCallback: (player: Player, badgeKey: number, announce: boolean?) -> ()) -> (),
}

local Badges = {}

Badges.Data = {} :: { Badge }

function Badges.GetBadgeFromKey(key: string): Badge
	for _, v in Badges.Data do
		if v.Key == key then
			return v
		end
	end

	return nil
end

function Badges.GetBadges()
	return Badges.Data
end

return Badges
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="ModuleScript" referent="394">
          <Properties>
            <string name="Name">BombManager</string>
            <string name="Source"><![CDATA[--[[
	BombManager

	Purpose:
		Keeps track of who currently has the bomb and syncs that holder to
		all clients. This module is intentionally small: it does not decide
		who is alive, who is allowed to receive a pass, when the bomb explodes,
		or when a match starts/ends. Those are round rules and live in
		RoundManager.

	What this owns:
		- The current bomb holder (`_bombHolder`)
		- `SyncBombHolder` server -> client replication
		- `OnHolderChanged`, so other server code can react to holder changes
		- A visual hook stub (`_onHolderChanged`) for bomb attach / handoff VFX

	What this does NOT own:
		- The alive-player list
		- Circle positions / pass direction math
		- `RequestBombPass` validation
		- Music / explosion timestamps
		- Eliminations, rewards, placements, or winner logic

	How it is used:
		1. RoundManager validates game rules.
		2. If a pass/random assignment is valid, RoundManager calls
		   `BombManager:SetHolder(player)`.
		3. BombManager updates `_bombHolder`, fires `SyncBombHolder`, and
		   triggers `OnHolderChanged`.

	BridgeNet2 notes:
		- `RequestBombPass` is referenced here only so both managers use the
		  same bridge name, but RoundManager is the module that connects to it
		  and validates requests.
		- `SyncBombHolder` is fired from here because holder sync is the bomb's
		  one real responsibility.
]]

-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local Signal = require(Packages.Signal)

--
local BombManager = {
	-- BridgeNet2 bridges (server creates, clients ReferenceBridge by same name)
	RequestBombPass = BridgeNet2.ReferenceBridge("RequestBombPass"),
	SyncBombHolder = BridgeNet2.ReferenceBridge("SyncBombHolder"),

	-- Server-side signals
	OnHolderChanged = Signal.new(),

	-- State
	_bombHolder = nil :: Player?,
}

----------------------------------------------------------------
-- Holder management
----------------------------------------------------------------

function BombManager:SetHolder(player: Player?)
	if self._bombHolder == player then
		return
	end

	self._bombHolder = player
	self.SyncBombHolder:Fire(BridgeNet2.AllPlayers(), { UserId = player and player.UserId or nil })
	self.OnHolderChanged:Fire(player)

	-- HOOK: visual effects (attach bomb model to character, glow, etc.)
	-- Add your code here or listen to OnHolderChanged from another script.
	self:_onHolderChanged(player)
end

function BombManager:GetHolder(): Player?
	return self._bombHolder
end

----------------------------------------------------------------
-- Hooks (override or listen via signals)
----------------------------------------------------------------

function BombManager:_onHolderChanged(_player: Player?)
	-- HOOK: Attach bomb model, play hand-off VFX/SFX, etc.
end

----------------------------------------------------------------
-- Lifecycle
----------------------------------------------------------------

function BombManager:OnInit() end

function BombManager:OnStart()
	-- NOTE: client `RequestBombPass` requests are handled by `RoundManager`,
	-- which validates against its alive list and circle order, then calls
	-- BombManager:SetHolder(target) on success. We don't connect here.
end

return BombManager
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="395">
          <Properties>
            <string name="Name">CodeManager</string>
            <string name="Source"><![CDATA[-- Services
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local AnalyticsService = game:GetService("AnalyticsService")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)

--
local Codes = require(script.Codes)

--
local PlayerDataManager
local NotificationManager

--
local CodeManager = {
	ClaimCodeEvent = BridgeNet2.ReferenceBridge("ClaimCode"),
	_inCooldown = {},
}

function CodeManager:ClaimCode(player: Player, code: string)
	-- Add a debounce so that it wont call ts a billion times in 1 sec
	if self._inCooldown[player] then
		NotificationManager.NotifyNormalEvent:Fire(
			player,
			{ "Please wait a moment before redeeming another code!", 3, "Reject" }
		)
		return
	end

	self._inCooldown[player] = true
	task.delay(1, function()
		self._inCooldown[player] = false
	end)

	-- Check if the code is valid
	local codeData = Codes.GetCodeFromCode(code)
	if not codeData then
		NotificationManager.NotifyNormalEvent:Fire(player, { "Invalid code!", 5, "Reject" })
		return
	end

	-- Check if the player has already redeemed the code
	local hasData, playerData = PlayerDataManager:GetPlayerData(player):await()
	if not hasData then
		return
	end

	if table.find(playerData.RedeemedCodes, code) then
		NotificationManager.NotifyNormalEvent:Fire(player, { "You have already redeemed this code!", 5, "Reject" })
		return
	end

	-- Redeem the code
	table.insert(playerData.RedeemedCodes, code)
	PlayerDataManager:SetPlayerDataKey(player, "CodeRedeemed", playerData.CodeRedeemed)

	codeData.Callback(player)
	NotificationManager.NotifyNormalEvent:Fire(
		player,
		{ `Successfully Redeemed <font color="#ffd400">{code}</font> Code!`, 5, "CollectedReward" }
	)

	if codeData.OnClaimMessage then
		NotificationManager.NotifyNormalEvent:Fire(player, { codeData.OnClaimMessage, 5 })
	end

	task.spawn(function()
		pcall(function()
			AnalyticsService:LogCustomEvent(player, "Redeemed Code", 1, {
				[Enum.AnalyticsCustomFieldKeys.CustomField01.Name] = code,
			})
		end)
	end)
end

function CodeManager:OnInit()
	PlayerDataManager = require(script.Parent.PlayerDataManager)
	NotificationManager = require(script.Parent.NotificationManager)
end

function CodeManager:OnStart()
	self.ClaimCodeEvent:Connect(function(player: Player, code: string)
		self:ClaimCode(player, code)
	end)

	Players.PlayerRemoving:Connect(function(player: Player)
		self._inCooldown[player] = nil
	end)
end

return CodeManager
]]></string>
          </Properties>
          <Item class="ModuleScript" referent="396">
            <Properties>
              <string name="Name">Codes</string>
              <string name="Source"><![CDATA[export type Code = {
	Code: string,
	OnClaimMessage: string,
	Callback: (player: Player) -> (),
}

--
local Codes = {}
Codes.Data = {}

function Codes.GetCodeFromCode(code: string): Code?
	for _, v in Codes.Data do
		if v.Code:lower() == code:lower() then
			return v
		end
	end

	return nil
end

return Codes
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="ModuleScript" referent="397">
          <Properties>
            <string name="Name">CurrencyManager</string>
            <string name="Source"><![CDATA[--
local PlayerDataManager

--
local CurrencyManager = {}

--
function CurrencyManager:IncrementCurrency(player: Player, amount: number?, ignoreBoosts: boolean?)
	amount = amount or 1

	if ignoreBoosts then
		return PlayerDataManager:IncrementDataKey(player, "Currency", amount)
	end

	--
	local addition = 0
	if player:HasTag("x2Coin") then
		addition += amount
	end

	if player:HasTag("VIP") then
		addition += math.round(amount * 0.25)
	end

	amount += addition
	PlayerDataManager:IncrementDataKey(player, "Currency", amount)
end

function CurrencyManager:DeductCurrency(player: Player, amount: number?)
	amount = amount or 1
	PlayerDataManager:DecrementDataKey(player, "Currency", amount)
end

function CurrencyManager:CanAfford(player: Player, amount: number): (boolean, number)
	local hasData, playerCurrency = PlayerDataManager:GetPlayerDataKey(player, "Currency"):await()
	if not hasData then
		return false
	end

	return playerCurrency >= amount, amount - playerCurrency
end

function CurrencyManager:OnInit()
	--
	PlayerDataManager = require(script.Parent.PlayerDataManager)
end

return CurrencyManager
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="398">
          <Properties>
            <string name="Name">DailyRewardManager</string>
            <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local AnalyticsService = game:GetService("AnalyticsService")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)

-- Shared
local Shared = ReplicatedStorage.Shared
local DailyRewardsConfig

--
local NotificationManager
local PlayerDataManager
local ShopManager

--
local DailyRewardManager = {
	ClaimRewardEvent = BridgeNet2.ReferenceBridge("ClaimDailyReward"),
}

--
function DailyRewardManager:ClaimReward(player: Player, skip: boolean?): boolean
	--
	local hasData, playerData = PlayerDataManager:GetPlayerData(player):await()
	if not hasData then
		return false
	end

	-- Checks if the player is eligible to claim the reward (skip if skip parameter is true)
	local currentTime = os.time()
	if not skip and (currentTime - playerData.LastDailyRewardClaim) < DailyRewardsConfig.CLAIM_INTERVAL then
		NotificationManager.NotifyNormalEvent:Fire(player, { "Come back later to claim your reward!", 6, "Reject" })
		ShopManager:AttemptProductPurchase(player, "SkipDay")
		return false
	end

	-- Check if the player has reached the max reward
	local currentStreak = playerData.DailyRewardStreak
	if currentStreak + 1 > DailyRewardsConfig.GetTotalRewards() then
		currentStreak = 0
	end

	-- Get the reward for the current day
	local rewardData = DailyRewardsConfig.GetRewardForDay(currentStreak + 1)
	if not rewardData then
		return false
	end

	-- Grant the reward
	rewardData.Callback(player)
	NotificationManager.NotifyNormalEvent:Fire(
		player,
		{ `Successfully Claimed <font color="#ffd400">Day {currentStreak + 1}</font> Reward!`, 6, "CollectedReward" }
	)

	PlayerDataManager:SetPlayerDataKey(player, "DailyRewardStreak", currentStreak + 1)
	PlayerDataManager:SetPlayerDataKey(player, "LastDailyRewardClaim", currentTime)

	--
	AnalyticsService:LogCustomEvent(player, "Daily Reward Day Claimed", 1, {
		[Enum.AnalyticsCustomFieldKeys.CustomField01.Name] = `Day {currentStreak + 1}`,
	})

	return true
end

-- Collects all remaining daily rewards for the player
function DailyRewardManager:CollectAllRewards(player: Player): boolean
	--
	local hasData, playerData = PlayerDataManager:GetPlayerData(player):await()
	if not hasData then
		return false
	end

	local currentTime = os.time()
	local currentStreak = playerData.DailyRewardStreak
	local totalRewards = DailyRewardsConfig.GetTotalRewards()

	-- Calculate how many rewards are left to claim
	local rewardsToClaim = totalRewards - currentStreak
	if rewardsToClaim <= 0 then
		-- Player has already claimed all rewards, reset streak
		currentStreak = 0
		rewardsToClaim = totalRewards
	end

	-- Grant all remaining rewards
	for i = 1, rewardsToClaim do
		local dayToClaim = currentStreak + i
		local rewardData = DailyRewardsConfig.GetRewardForDay(dayToClaim)
		if rewardData then
			rewardData.Callback(player)

			-- Log analytics for each reward
			AnalyticsService:LogCustomEvent(player, "Daily Reward Day Claimed", 1, {
				[Enum.AnalyticsCustomFieldKeys.CustomField01.Name] = `Day {dayToClaim}`,
			})
		end
	end

	-- Update streak to max and update last claim time
	PlayerDataManager:SetPlayerDataKey(player, "DailyRewardStreak", totalRewards)
	PlayerDataManager:SetPlayerDataKey(player, "LastDailyRewardClaim", currentTime)

	-- Send notification
	NotificationManager.NotifyNormalEvent:Fire(player, {
		`Successfully Claimed <font color="#ffd400">All {rewardsToClaim} Daily Rewards</font>!`,
		6,
		"CollectedReward",
	})

	return true
end

-- Attempt to reset the player's daily reward streak if they missed a day
function DailyRewardManager:_attemptResetStreak(player: Player)
	--
	local hasData, playerData = PlayerDataManager:GetPlayerData(player):await()
	if not hasData then
		return
	end

	--
	if os.time() - playerData.LastDailyRewardClaim >= DailyRewardsConfig.CLAIM_INTERVAL * 2 then
		playerData.DailyRewardStreak = 0
	end
end

function DailyRewardManager:OnInit()
	PlayerDataManager = require(script.Parent.PlayerDataManager)
	NotificationManager = require(script.Parent.NotificationManager)
	ShopManager = require(script.Parent.ShopManager)

	DailyRewardsConfig = require(Shared.Config.DailyRewards)

	Players.PlayerAdded:Connect(function(player)
		self:_attemptResetStreak(player)
	end)
end

function DailyRewardManager:OnStart()
	self.ClaimRewardEvent.OnServerInvoke = function(player: Player, skip: boolean?)
		return self:ClaimReward(player, skip)
	end
end

return DailyRewardManager
]]></string>
          </Properties>
        </Item>
