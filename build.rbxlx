                <string name="Source">return {
	package = {
		authors = {"Xan_TheDragon"},
		description = "A port of PartCache by Xan_TheDragon to Wally. Modified with proper OOP strict-typing.",
		exclude = {"foreman.toml"},
		name = "andremhpra/partcache",
		realm = "shared",
		registry = "https://github.com/UpliftGames/wally-index",
