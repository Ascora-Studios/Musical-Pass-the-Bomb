          <Item class="ModuleScript" referent="447">
            <Properties>
              <string name="Name">UIRainbow</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- Packages
local Packages = ReplicatedStorage.Packages
local Component = require(Packages.Component)

--
local RainbowUI = Component.new({
	Tag = script.Name,
})

function RainbowUI:Construct()
	--
	local ui = self.Instance

	--
	local rainbowGradient = ui:IsA("UIStroke") and ui or Instance.new("UIGradient")
	rainbowGradient.Parent = ui

	local time = ui:GetAttribute("RainbowSpeed") or 2 -- amount of time it takes to get from 0 to 1
	local range = 10 -- amount of colors

	--
	RunService.Heartbeat:Connect(function()
		local loop = tick() % time / time
		local colors = {}

		for i = 1, range + 1, 1 do
			z = Color3.fromHSV(loop - ((i - 1) / range), 1, 1)

			if loop - ((i - 1) / range) < 0 then
				z = Color3.fromHSV((loop - ((i - 1) / range)) + 1, 1, 1)
			end

			local d = ColorSequenceKeypoint.new((i - 1) / range, z)
			table.insert(colors, d)
		end

		rainbowGradient.Color = ColorSequence.new(colors)
	end)
end

return RainbowUI
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="448">
            <Properties>
              <string name="Name">UIRotate</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- Packages
local Packages = ReplicatedStorage.Packages
local Component = require(Packages.Component)

--
local UIRotate = Component.new({
	Tag = script.Name,
})

function UIRotate:Construct()
	local uiElement = self.Instance
	local speed = uiElement:GetAttribute("Speed") or 0.25

	RunService.Heartbeat:Connect(function(deltaTime)
		uiElement.Rotation += speed * 60 * deltaTime
	end)
end

return UIRotate
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="449">
            <Properties>
              <string name="Name">UISway</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- Packages
local Packages = ReplicatedStorage.Packages
local Component = require(Packages.Component)
local Trove = require(Packages.Trove)

--
local UISway = Component.new({
	Tag = script.Name,
})

function UISway:Construct()
	local ui = self.Instance

	self._cleaner = Trove.new()

	local amplitude = ui:GetAttribute("Amplitude") or 5 -- max rotation in degrees
	local speed = ui:GetAttribute("Speed") or 1 -- cycles per second
	local offset = ui:GetAttribute("Offset") or 0 -- phase offset in seconds

	self._defaultRotation = ui.Rotation

	self._cleaner:Add(RunService.RenderStepped:Connect(function()
		ui.Rotation = self._defaultRotation + amplitude * math.sin((tick() + offset) * speed * math.pi * 2)
	end))

	self._cleaner:Add(function()
		ui.Rotation = self._defaultRotation
	end)
end

function UISway:Stop()
	self._cleaner:Destroy()
end

return UISway
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="450">
            <Properties>
              <string name="Name">VIP</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- Packages
local Packages = ReplicatedStorage.Packages
local Component = require(Packages.Component)
local Trove = require(Packages.Trove)

-- Assets
local Assets = ReplicatedStorage.Assets
local Meshes = Assets.Meshes

-- Constants
local CROWN_HEIGHT_OFFSET = 1.4
local CROWN_LERP_SPEED = 0.2

--
local ActiveCrowns = {}
local UpdateConnection: RBXScriptConnection?

--
local CrownsFolder = Instance.new("Folder")
CrownsFolder.Name = "VIPCrowns"
CrownsFolder.Parent = workspace

--
local VIPCrown = Component.new({
	Tag = script.Name,
})

local rot = 0
local function updateCrowns(dt: number)
	local alpha = math.clamp(CROWN_LERP_SPEED * dt * 60, 0.4, 1)
	rot += 20 * dt

	for vipCrown in pairs(ActiveCrowns) do
		vipCrown:_updateCrown(alpha)
	end
end

function VIPCrown:_updateCrown(alpha: number)
	--
	local character: Model = self._character
	local crown: BasePart = self._crown

	if not character or not crown then
		return
	end

	--
	local finalCFrame = character:GetPivot() * self._offset * CFrame.Angles(0, math.rad(rot), 0)

	--
	crown.CFrame = crown.CFrame:Lerp(finalCFrame, alpha)
end

function VIPCrown:_createCrown(character: Model)
	--
	self._crownCleaner:Clean()

	--
	local rootPart: BasePart? = character:FindFirstChild("HumanoidRootPart")
		or character:WaitForChild("HumanoidRootPart", 5)

	if not rootPart then
		return
	end

	--
	local characterSize = character:GetExtentsSize()
	local offset = CFrame.new(0, (characterSize.Y / 2) + CROWN_HEIGHT_OFFSET, 0)

	--
	local crown: BasePart = Meshes.VIPCrown:Clone()
	crown.Anchored = true
	crown.CanCollide = false
	crown.CanQuery = false
	crown.CanTouch = false
	crown.Massless = true
	crown.CFrame = rootPart.CFrame * offset
	crown.Parent = CrownsFolder

	--
	self._character = character
	self._crown = crown
	self._offset = offset

	--
	ActiveCrowns[self] = true

	if not UpdateConnection then
		UpdateConnection = RunService.RenderStepped:Connect(updateCrowns)
	end

	self._crownCleaner:Add(function()
		ActiveCrowns[self] = nil

		if not next(ActiveCrowns) and UpdateConnection then
			UpdateConnection:Disconnect()
			UpdateConnection = nil
		end
	end)

	self._crownCleaner:Add(crown)
end

function VIPCrown:Construct()
	--
	local vipPlayer: Player = self.Instance

	--
	self._cleaner = Trove.new()
	self._crownCleaner = self._cleaner:Extend()

	--
	if vipPlayer.Character then
		self:_createCrown(vipPlayer.Character)
	end

	--
	self._cleaner:Add(vipPlayer.CharacterAdded:Connect(function(character: Model)
		self:_createCrown(character)
	end))
end

function VIPCrown:Stop()
	self._cleaner:Destroy()
end

return VIPCrown
]]></string>
            </Properties>
          </Item>
        </Item>
        <Item class="Folder" referent="451">
          <Properties>
            <string name="Name">Controllers</string>
          </Properties>
          <Item class="ModuleScript" referent="452">
            <Properties>
              <string name="Name">AbilitiesController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local Spr = require(Packages.Spr)

-- Local Player
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

-- Shared
local Shared = ReplicatedStorage.Shared
local Abilities = Shared.Abilities

--
local PlayerDataController
local HudController
local ShopController
local UIController
local SelectPlayerController

--
local AbilitiesController = {
	--
	UseAbilityEvent = BridgeNet2.ReferenceBridge("UseAbility"),
	OnUseAbilityEvent = BridgeNet2.ReferenceBridge("OnUseAbility"),
	RequestAbilityPurchaseEvent = BridgeNet2.ReferenceBridge("RequestAbilityPurchase"),

	_abilities = {},
}

function AbilitiesController:RequestAbilityPurchase(ability: string, selectedUserId: number?)
	if type(ability) ~= "string" then
		return
	end

	if selectedUserId then
		self.RequestAbilityPurchaseEvent:Fire({
			Ability = ability,
			SelectedUserId = selectedUserId,
		})
	else
		self.RequestAbilityPurchaseEvent:Fire(ability)
	end
end

function AbilitiesController:RequestUseAbility(ability: string, selectedUserId: number?)
	if type(ability) ~= "string" then
		return
	end

	if selectedUserId then
		self.UseAbilityEvent:Fire({
			Ability = ability,
			SelectedUserId = selectedUserId,
		})
	else
		self.UseAbilityEvent:Fire(ability)
	end
end

function AbilitiesController:_setupUI()
	local ui = self.UI
	local holder = ui.Holder
	local container = holder.Container.ScrollingFrame

	local playerReplica

	local function requestAbility(abilityName: string, selectedUserId: number?)
		local ownedAmount = 0
		if playerReplica then
			ownedAmount = (playerReplica.Data.Abilities or {})[abilityName] or 0
		end

		if LocalPlayer:GetAttribute("InGame") == true and ownedAmount > 0 then
			self:RequestUseAbility(abilityName, selectedUserId)
		else
			self:RequestAbilityPurchase(abilityName, selectedUserId)
		end
	end

	-- Bind the buttons
	for _, ability in Abilities:GetChildren() do
		local configFile = require(ability.Config)

		--
		local abilityTemplate = container.AbilityTemplate:Clone()
		abilityTemplate.Name = ability.Name
		abilityTemplate.Holder.Description.Text = configFile.Description
		abilityTemplate.Holder.Title.Text = configFile.Name
		abilityTemplate.Holder.Icon.Image = configFile.Icon
		abilityTemplate.Holder.Price.CurrencyPurchaseGradient.Enabled = configFile.IsCurrencyPurchase
		abilityTemplate.Holder.Price.RobuxPurchaseGradient.Enabled = configFile.IsRobuxPurchase
		abilityTemplate.Holder.Ray.Visible = configFile.IsRobuxPurchase
		abilityTemplate.Visible = true
		abilityTemplate.LayoutOrder = configFile.IsCurrencyPurchase and configFile.Price or -1
		abilityTemplate.Parent = container

		task.spawn(function()
			local price = configFile.IsRobuxPurchase and ShopController:GetPrice(ability.Name) or configFile.Price
			abilityTemplate.Holder.Price.Text = configFile.IsCurrencyPurchase and `${price}`
				or `{utf8.char(0xE002)}{price}`
		end)

		UIController:BindButtonClick(abilityTemplate.Holder.Button, function()
			if configFile.SelectPlayer and LocalPlayer:GetAttribute("InGame") == true then
				SelectPlayerController:OpenForAbility(ability.Name, function(selectedUserId: number)
					requestAbility(ability.Name, selectedUserId)
				end)
				return
			end

			requestAbility(ability.Name)
		end, true, false, { ShowFrame = abilityTemplate.Holder })
	end

	-- Update the abilities
	local function updateAbilities()
		for _, ability in Abilities:GetChildren() do
			local abilityTemplate = container:FindFirstChild(ability.Name)
			if abilityTemplate then
				local ownedAmount = playerReplica.Data.Abilities[ability.Name] or 0
				abilityTemplate.Holder.Amount.Text = `x{ownedAmount}`
			end
		end
	end

	-- Update the abilities when the player data changes
	PlayerDataController:GetReplica():andThen(function(replica)
		playerReplica = replica
		updateAbilities()

		replica:OnChange(function(_, path)
			if path[1] == "Abilities" then
				updateAbilities()
			end
		end)
	end)

	-- Bind the exit button
	UIController:BindButtonClick(holder.Exit, function()
		UIController:CloseFrame(holder)
	end, true)

	-- Bind the hud button
	HudController:BindHudButton("Abilities", function()
		UIController:OpenFrame(holder)
	end)
end

function AbilitiesController:OnInit()
	PlayerDataController = require(script.Parent.PlayerDataController)
	ShopController = require(script.Parent.ShopController)
	UIController = require(script.Parent.UIController)
	HudController = require(script.Parent.HudController)
	SelectPlayerController = require(script.Parent.SelectPlayerController)

	self.UI = PlayerGui:WaitForChild("AbilitiesUI")

	for _, ability in Abilities:GetChildren() do
		self._abilities[ability.Name] = require(ability.Client)
	end
end

function AbilitiesController:OnStart()
	self.UseAbilityEvent:Connect(function(data)
		local ability = data[1]
		local role = data[2]

		local abilityModule = self._abilities[ability]
		if not abilityModule then
			warn(`Ability {ability} not found.`)
			return
		end

		if role == "Victim" and abilityModule.OnVictim then
			abilityModule.OnVictim()
		elseif role == "Activator" and abilityModule.OnActivated then
			abilityModule.OnActivated()
		end
	end)

	task.spawn(AbilitiesController._setupUI, self)
end

return AbilitiesController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="453">
            <Properties>
              <string name="Name">AnimationController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local Replica = require(Packages.Replica)

-- Shared
local Shared = ReplicatedStorage.Shared
local Animations = require(Shared.Animations)

-- Local Player
local LocalPlayer = Players.LocalPlayer

--
local AnimationController = {
	_animationTracks = {},
}

function AnimationController:PlayAnimation(animationName: string)
	local animationTrack = self._animationTracks[animationName]
	if not animationTrack then
		warn("Animation not found:", animationName)
		return
	end

	animationTrack:Play()
end

function AnimationController:StopAnimation(animationName: string)
	local animationTrack = self._animationTracks[animationName]
	if not animationTrack then
		warn("Animation not found:", animationName)
		return
	end

	animationTrack:Stop()
end

function AnimationController:_initAnimations()
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

	for animationName, animatiodId in Animations do
		--
		local animation = Instance.new("Animation")
		animation.Name = animationName
		animation.AnimationId = animatiodId

		local animationTrack = character.Humanoid.Animator:LoadAnimation(animation)
		self._animationTracks[animationName] = animationTrack
	end
end

function AnimationController:OnInit()
	LocalPlayer.CharacterAdded:Connect(function()
		self:_initAnimations()
	end)

	self:_initAnimations()
end

return AnimationController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="454">
            <Properties>
              <string name="Name">CameraController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local CameraShaker = require(Packages.CameraShaker)

--
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

--
local CameraController = {
	Camera = Camera,
	_cameraShaker = nil,
	_lockedCFrame = nil,
}

--
local function validateCameraShaker(self: any): boolean
	if not self._cameraShaker then
		warn("Camera shaker not initialized")
		return false
	end
	return true
end

-- Shakes the camera once with custom parameters
-- @param magnitude The magnitude of the shake
-- @param roughness The roughness of the shake
-- @param fadeInTime Time to fade in the shake
-- @param fadeOutTime Time to fade out the shake
-- @param posInfluence Position influence vector
-- @param rotInfluence Rotation influence vector
function CameraController:ShakeCustom(
	magnitude: number,
	roughness: number,
	fadeInTime: number,
	fadeOutTime: number,
	posInfluence: Vector3,
	rotInfluence: Vector3
)
	if not validateCameraShaker(self) then
		return
	end

	self._cameraShaker:ShakeOnce(magnitude, roughness, fadeInTime, fadeOutTime, posInfluence, rotInfluence)
end

-- Sets the camera to a specific CFrame position
-- @param cframe The target CFrame or BasePart to set the camera to
-- @param animate Whether to animate the camera movement (uses tween) or set instantly
-- @param tweenInfo Optional TweenInfo for the animation (defaults to 0.4s Sine easing)
-- @remarks When a CFrame is locked, camera shake will be applied relative to this locked position
function CameraController:SetCameraCFrameTo(cframe: CFrame | BasePart, animate: boolean, tweenInfo: TweenInfo?)
	if typeof(cframe) == "Instance" then
		cframe = cframe.CFrame
	end

	tweenInfo = tweenInfo or TweenInfo.new(0.4, Enum.EasingStyle.Sine)
	Camera.CameraType = Enum.CameraType.Scriptable

	if animate then
		TweenService:Create(Camera, tweenInfo, { CFrame = cframe }):Play()
		task.delay(tweenInfo.Time, function()
			if not (Camera.CameraType == Enum.CameraType.Scriptable) then
				return
			end

			self._lockedCFrame = cframe
		end)
	else
		Camera.CFrame = cframe
		self._lockedCFrame = cframe
	end
end

-- Resets the camera back to default behavior
-- @remarks Unlocks the camera CFrame and sets camera type back to Custom, allowing normal camera following
function CameraController:SetBackToDefault()
	self._lockedCFrame = nil
	Camera.CameraType = Enum.CameraType.Custom
end

-- Shakes the camera using a preset
-- @param presetName The name of the preset to use
function CameraController:ShakePreset(presetName: string)
	if not validateCameraShaker(self) then
		return
	end

	if not CameraShaker.Presets[presetName] then
		warn(`Camera shake preset '{presetName}' not found`)
		return
	end

	self._cameraShaker:Shake(CameraShaker.Presets[presetName])
end

-- Starts a sustained camera shake
-- @param magnitude The magnitude of the shake
-- @param roughness The roughness of the shake
-- @param fadeInTime Time to fade in the shake
-- @param fadeOutTime Time to fade out the shake
-- @param posInfluence Position influence vector
-- @param rotInfluence Rotation influence vector
function CameraController:ShakeSustain(
	magnitude: number,
	roughness: number,
	fadeInTime: number,
	fadeOutTime: number,
	posInfluence: Vector3,
	rotInfluence: Vector3
)
	if not validateCameraShaker(self) then
		return
	end

	self._cameraShaker:StartShake(magnitude, roughness, fadeInTime, fadeOutTime, posInfluence, rotInfluence)
end

-- Stops a sustained camera shake
function CameraController:StopShakeSustain(duration: number)
	if not validateCameraShaker(self) then
		return
	end

	self._cameraShaker:StopSustained(duration)
end

-- Sets the camera subject
-- @param subject Optional subject to set (defaults to player's humanoid)
function CameraController:SetSubject(subject: Instance?)
	local character = LocalPlayer.Character
	if not character then
		warn("Player character not found")
		return
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		warn("Player humanoid not found")
		return
	end

	Camera.CameraSubject = subject or humanoid
end

function CameraController:OnInit()
	local camShake = CameraShaker.new(Enum.RenderPriority.Camera.Value, function(shakeCFrame: CFrame)
		local offset = self._lockedCFrame or Camera.CFrame
		Camera.CFrame = offset * shakeCFrame
	end)

	camShake:Start()
	self._cameraShaker = camShake
end

function CameraController:OnStart() end

return CameraController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="455">
            <Properties>
              <string name="Name">CurrencyController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

-- Packages
local Packages = ReplicatedStorage.Packages

-- Shared
local Shared = ReplicatedStorage.Shared
local GuiUtil = require(Shared.GuiUtil)

-- Local Player
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

--
local PlayerDataController
local EffectController

--
local CurrencyController = {
	_previousThread = nil,
}

function CurrencyController:OnIncrementCurrency(new: number, old: number?)
	local hudUI = self.HudUI
	local currency = hudUI.Left.Currency

	if self._previousThread then
		task.cancel(self._previousThread)
		self._previousThread = nil
	end

	local difference = new - (old or 0)

	GuiUtil.AnimateNumberTo(new, false, 0.5, function(value)
		currency.Amount.Text = GuiUtil.ConvertNumberWithCommas(value)
	end, old)

	TweenService:Create(
		currency.UIScale,
		TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.InOut, 0, true),
		{ Scale = 1.1 }
	):Play()

	self._previousThread = task.delay(1, function()
		TweenService:Create(
			currency.UIScale,
			TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut, 0, true),
			{ Scale = 1 }
		):Play()
	end)

	-- if coin increased then do effe
	if difference > 0 then
		EffectController:RunEffect("CoinReceived", LocalPlayer)
	end
end

function CurrencyController:OnInit()
	PlayerDataController = require(script.Parent.PlayerDataController)
	EffectController = require(script.Parent.EffectController)

	self.HudUI = PlayerGui:WaitForChild("HudUI")

	PlayerDataController:GetReplica():andThen(function(replica)
		self.HudUI.Left.Currency.Amount.Text = GuiUtil.ConvertNumberWithCommas(replica.Data.Currency)
		replica:OnSet({ "Currency" }, function(new, old)
			self:OnIncrementCurrency(new, old)
		end)
	end)
end

return CurrencyController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="456">
            <Properties>
              <string name="Name">CustomizedChatController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TextChatService = game:GetService("TextChatService")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages

local CHAT_TAGS = {
	["VIP"] = "<font color='#ffd902'>[VIP]</font>",
}

local CHAT_BOX_MESSAGES = {}

local CHAT_BOX_MESSAGES_COLOR = {
	Color3.fromHex("#ffff7f"),
	Color3.fromHex("#ffaaff"),
	Color3.fromHex("#aaffff"),
	Color3.fromHex("#ff7f7f"),
	Color3.fromHex("#7fff7f"),
}

local MIN_TIME_CHAT_MESSAGE = 7 * 60
local MAX_TIME_CHAT_MESSAGE = 10 * 60

--
local ChatTagController = {}

--
function ChatTagController:OnInit()
	-- Setup tag adder
	TextChatService.OnIncomingMessage = function(message: TextChatMessage)
		local textChatProperties = Instance.new("TextChatMessageProperties")
		if not message.TextSource then
			return
		end

		-- Get player
		local playerChatted = Players:GetPlayerByUserId(message.TextSource.UserId)
		if not playerChatted then
			return
		end

		--
		local isPlayerVIP = playerChatted:HasTag("VIP")

		-- Add VIP Tag
		local tagPrefix = ""
		if isPlayerVIP then
			tagPrefix = `{tagPrefix} {CHAT_TAGS.VIP}`
		end

		-- Add player title on Tag
		tagPrefix = `{tagPrefix}`

		-- Set Prefix
		textChatProperties.PrefixText = `{tagPrefix} {message.PrefixText}`
		return textChatProperties
	end

	-- Connect the loop for the chatbox server messages
	--[[task.spawn(function()
		while true do
			local randomText = CHAT_BOX_MESSAGES[math.random(1, #CHAT_BOX_MESSAGES)]
			TextChatService.TextChannels.RBXSystem:DisplaySystemMessage(
				`<font color="#{CHAT_BOX_MESSAGES_COLOR[math.random(1, #CHAT_BOX_MESSAGES_COLOR)]:ToHex()}">{randomText}</font>`
			)

			-- Cooldown with a random amount
			task.wait(math.random(MIN_TIME_CHAT_MESSAGE, MAX_TIME_CHAT_MESSAGE))
		end
	end)]]
end

function ChatTagController:OnStart() end

return ChatTagController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="457">
            <Properties>
              <string name="Name">EffectController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)

--
local Effects = script.Parent.Parent.Effects

--
local RunEffect = BridgeNet2.ReferenceBridge("RunEffect")

--
local EffectController = {
	_effects = {},
}

function EffectController:RunEffect(effect: string, ...)
	local effectModule = self._effects[effect]
	if not effectModule then
		warn("Effect not found:", effect)
		return
	end

	return effectModule(...)
end

function EffectController:OnInit()
	local EffectsFolder = Instance.new("Folder")
	EffectsFolder.Name = "Effects"
	EffectsFolder.Parent = workspace

	for _, v in Effects:GetChildren() do
		local effect = require(v)
		self._effects[v.Name] = effect
	end
end

function EffectController:OnStart()
	RunEffect:Connect(function(data: { any })
		self:RunEffect(table.unpack(data))
	end)
end

return EffectController
]]></string>
            </Properties>
          </Item>
          <Item class="ModuleScript" referent="458">
            <Properties>
              <string name="Name">GroupRewardController</string>
              <string name="Source"><![CDATA[-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

-- Packages
local Packages = ReplicatedStorage.Packages
local BridgeNet2 = require(Packages.BridgeNet2)
local ZonePlus = require(Packages.ZonePlus)

-- Local Player
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

--
local UIController

--
local GroupRewardController = {
	ClaimRewardEvent = BridgeNet2.ReferenceBridge("ClaimGroupReward"),
}

function GroupRewardController:_setupUI()
	local ui = self.UI
	local holder = ui.Holder

	--
	UIController:BindButtonClick(holder.Claim, function()
		self.ClaimRewardEvent:Fire()
	end, true)

	--
	local likeReward = workspace.Main.LikeReward

	local likeRewardZone = ZonePlus.new(likeReward.Hitbox)
	likeRewardZone.localPlayerEntered:Connect(function()
		UIController:OpenFrame(holder)
	end, true)

	UIController:BindButtonClick(holder.Exit, function()
		UIController:CloseFrame(holder)
	end, true)
end

function GroupRewardController:OnInit()
	UIController = require(script.Parent.UIController)
	self.UI = PlayerGui:WaitForChild("LikeGameUI")
end

function GroupRewardController:OnStart()
	task.spawn(GroupRewardController._setupUI, self)
end

return GroupRewardController
]]></string>
